# ─── Backend API ─────────────────────────────────────────────
NODE_ENV=development
API_PORT=3000
API_HOST=0.0.0.0
LOG_LEVEL=info

# ─── PostgreSQL ──────────────────────────────────────────────
DATABASE_URL=postgresql://sportlocker:sportlocker@localhost:5432/sportlocker

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── MQTT (EMQX) ─────────────────────────────────────────────
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=sportlocker
MQTT_PASSWORD=change-me

# ─── JWT signatures ──────────────────────────────────────────
# JWT pour les sessions utilisateurs (Firebase Auth → exchange)
JWT_SESSION_SECRET=change-me-64-chars-min
# JWT pour les QR codes offline signés par l'app mobile
JWT_DEVICE_SECRET=change-me-64-chars-min

# ─── Firebase Auth ───────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_KEY=

# ─── Stripe (paiement caution) ───────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Push notifications (Web Push / VAPID) ──────────────────
# Génération : `npx web-push generate-vapid-keys` (à faire UNE fois,
# stocker les valeurs dans Railway → @sportlocker/api → Variables).
# Sans ces clés, l'API démarre normalement mais le cron slot-reminders
# log un warn et n'envoie aucune notif (no-op).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@sportlocker.fr

# Legacy Expo Push — apps/mobile supprimé en mai 2026, gardé pour compat
# Railway au cas où la variable serait encore set. Peut être retiré.
EXPO_ACCESS_TOKEN=

# ─── Dashboard ───────────────────────────────────────────────
DASHBOARD_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3000

# Firebase Auth côté client dashboard — clés publiques du projet Firebase
# (mêmes valeurs que côté mobile, projet unique).
# À renseigner dans Railway service "dashboard" avant déploiement.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Sentry (observability, optionnel) ──────────────────────
# Si NEXT_PUBLIC_SENTRY_DSN est absent, le SDK reste no-op silencieux
# sur citizen + dashboard. Idem côté API avec SENTRY_DSN. Plan free :
# 5k errors + 10k perf events/mois.
#
# Création : https://sentry.io → New project → Next.js (×2 pour
# citizen + dashboard) + Node.js (pour l'API).
# Copie ensuite les DSN dans Railway pour chaque service.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Optionnel : upload des source maps au build pour avoir des stack
# traces déminifiées dans Sentry. Génère un token sur sentry.io →
# Settings → Account → API → User Auth Tokens (scope `project:releases`).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ─── Firmware (Raspberry Pi) ─────────────────────────────────
DEVICE_ID=
DEVICE_API_KEY=
