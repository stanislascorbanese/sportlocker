{
  "name": "sportlocker",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev":        "turbo run dev",
    "build":      "turbo run build",
    "lint":       "turbo run lint",
    "test":       "turbo run test",
    "typecheck":  "turbo run typecheck",
    "clean":      "turbo run clean && rm -rf node_modules",
    "db:migrate": "pnpm --filter @sportlocker/api db:migrate",
    "db:studio":  "pnpm --filter @sportlocker/api db:studio"
  },
  "devDependencies": {
    "turbo":            "^2.0.0",
    "typescript":       "^5.4.0",
    "eslint":           "^8.57.0",
    "@types/node":      "^20.0.0",
    "prettier":         "^3.2.0"
  }
}
