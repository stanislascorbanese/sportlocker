{
  "expo": {
    "name": "SportLocker",
    "slug": "sportlocker",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "sportlocker",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "fr.sportlocker.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Scanner les QR codes pour déverrouiller les casiers",
        "NSLocationWhenInUseUsageDescription": "Trouver les distributeurs à proximité"
      }
    },
    "android": {
      "package": "fr.sportlocker.app",
      "permissions": ["CAMERA", "ACCESS_FINE_LOCATION", "NFC"]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-location",
      "expo-notifications"
    ],
    "experiments": { "typedRoutes": true }
  }
}
