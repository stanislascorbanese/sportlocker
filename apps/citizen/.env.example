# Firebase Auth — projet SportLocker (sportlocker-f85b7).
# Mêmes valeurs que apps/dashboard, c'est le même projet Firebase.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# URL publique de l'API SportLocker (Fastify).
NEXT_PUBLIC_API_URL=https://api.sportlocker.fr

# Clé publique Stripe (pk_test_… en dev, pk_live_… en prod). Requise seulement
# quand l'API tourne en PAYMENTS_PROVIDER=stripe. En mode simulate, laisser vide.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
