---
import '@/styles/global.css'
import Nav from '@/components/Nav.astro'
import Footer from '@/components/Footer.astro'
import { SITE } from '@/data/site'

interface Props {
  title: string
  description?: string
  canonical?: string
  ogImage?: string
  noindex?: boolean
  // Schemas additionnels (Service, BreadcrumbList, FAQPage…) injectés après
  // le schema Organization. Le `@context` est ajouté automatiquement.
  extraJsonLd?: Record<string, unknown>[]
}

const {
  title,
  description = SITE.description,
  canonical,
  ogImage = SITE.defaultOgImage,
  noindex = false,
  extraJsonLd = [],
} = Astro.props

const pageTitle = title.includes(SITE.name) ? title : `${title} — ${SITE.name}`
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, SITE.url).toString()
const ogImageUrl = new URL(ogImage, SITE.url).toString()

// Organization enrichi pour les Knowledge Panels Google (logo, contactPoint,
// areaServed). `sameAs` reste vide tant qu'on n'a pas de profils sociaux
// officiels — Google préfère un tableau absent à un tableau avec des liens
// 404. La logo URL doit pointer sur un PNG carré ≥ 112px (recommandation
// schema.org).
const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE.legalName,
  alternateName: SITE.name,
  url: SITE.url,
  email: SITE.email,
  description: SITE.description,
  logo: new URL('/favicon-v4.png', SITE.url).toString(),
  image: new URL(SITE.defaultOgImage, SITE.url).toString(),
  areaServed: {
    '@type': 'Country',
    name: 'France',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'customer service',
    email: SITE.email,
    availableLanguage: ['French'],
  },
}

// Schema WebSite : aide Google à identifier l'entité « site » (nom, langue,
// éditeur). Pas de SearchAction (sitelinks searchbox) car la vitrine n'a pas
// de moteur de recherche interne — déclarer un potentialAction non fonctionnel
// serait trompeur.
const webSiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.name,
  alternateName: SITE.legalName,
  url: SITE.url,
  description: SITE.description,
  inLanguage: 'fr-FR',
  publisher: {
    '@type': 'Organization',
    name: SITE.legalName,
    url: SITE.url,
  },
}

const pageJsonLd = extraJsonLd.map((schema) => ({
  '@context': 'https://schema.org',
  ...schema,
}))
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={pageTitle} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={pageTitle} />

    <!--
      Cache-bust favicon : on change le BASENAME du fichier (favicon → favicon-v3),
      pas un query string `?v=`. Safari indexe les favicons par l'URL de la PAGE,
      pas par celle de l'icône, donc un `?v=2` ne suffit pas à le forcer à re-fetch
      (cf. apps/citizen/src/app/layout.tsx, même technique éprouvée sur app/ops).
      Le `?v=2` historique du 22/05 (recolorisation bleu→vert) laissait Safari sur
      l'ancien logo bleu. v3 (08/06) = tailles propres + basename neuf.
      v4 (09/06) : v3 n'affichait que la porte verte (le "S" et le ballon étaient
      un tracé blanc fantôme, invisible sur fond blanc → tuile écran d'accueil et
      ligne de résultat Google amputées de la moitié du logo). v4 part des assets
      de marque pleins : favicons = `logo-mark.png` (marque SL complète, fond
      transparent, lisible en petit + s'adapte clair/sombre), apple-touch =
      `logo-icon-filled.png` (tuile vert foncé pleine, idéale écran d'accueil iOS).
    -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32-v4.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192-v4.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-v4.png" />
    <link rel="shortcut icon" type="image/png" href="/favicon-32-v4.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon-v4.png" />
    <meta name="theme-color" content="#0D1B2A" />

    <!-- Playfair Display — display serif for headlines -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;0,900;1,700;1,800&display=swap"
      rel="stylesheet"
    />

    <!-- Dark mode: apply before paint to avoid flash -->
    <script is:inline>
      ;(function () {
        const saved = localStorage.getItem('sl-theme')
        if (saved === 'light') document.documentElement.classList.add('light')
      })()
    </script>

    <script
      type="application/ld+json"
      set:html={JSON.stringify(orgJsonLd)}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(webSiteJsonLd)}
    />
    {pageJsonLd.map((schema) => (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(schema)}
      />
    ))}
  </head>
  <body>
    <a href="#main" class="skip-link">Aller au contenu</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Animated counters
      const counterObs = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue
            const el = entry.target as HTMLElement
            const target = Number(el.dataset.counter)
            if (!target) continue
            counterObs.unobserve(el)
            const duration = 1600
            const start = performance.now()
            const suffix = el.dataset.counterSuffix ?? ''
            const run = (now: number) => {
              const elapsed = now - start
              const progress = Math.min(elapsed / duration, 1)
              const eased = 1 - Math.pow(1 - progress, 3)
              el.textContent = Math.floor(eased * target).toLocaleString('fr-FR') + suffix
              if (progress < 1) requestAnimationFrame(run)
            }
            requestAnimationFrame(run)
          }
        },
        { threshold: 0.5 },
      )
      document.querySelectorAll('[data-counter]').forEach((el) => counterObs.observe(el))

      // Dark/light toggle
      const toggleTheme = () => {
        const isLight = document.documentElement.classList.toggle('light')
        localStorage.setItem('sl-theme', isLight ? 'light' : 'dark')
        document.querySelectorAll<HTMLElement>('[data-theme-icon]').forEach((icon) => {
          icon.textContent = isLight ? '☀️' : '🌙'
        })
      }
      document.querySelectorAll('[data-theme-toggle]').forEach((btn) => {
        btn.addEventListener('click', toggleTheme)
      })
      // Set initial icon
      const isLight = document.documentElement.classList.contains('light')
      document.querySelectorAll<HTMLElement>('[data-theme-icon]').forEach((icon) => {
        icon.textContent = isLight ? '☀️' : '🌙'
      })
    </script>

    <script>
      // Fade in on scroll for elements with data-reveal
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('reveal-visible')
              io.unobserve(e.target)
            }
          }
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' },
      )
      document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el))
    </script>

    <style is:global>
      /* Skip link : masqué hors focus clavier, révélé au Tab en haut à gauche,
         au-dessus de la nav fixe (z-index > #nav). */
      .skip-link {
        position: fixed;
        top: 0.75rem;
        left: 0.75rem;
        z-index: 200;
        padding: 0.6rem 1rem;
        border-radius: 0.5rem;
        background: #1d9e75;
        color: #fff;
        font-size: 0.875rem;
        font-weight: 600;
        text-decoration: none;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
        transform: translateY(calc(-100% - 1rem));
        transition: transform 0.18s ease;
      }
      .skip-link:focus {
        transform: translateY(0);
        outline: 2px solid #fff;
        outline-offset: 2px;
      }

      [data-reveal] {
        opacity: 0;
        transform: translateY(28px);
        transition:
          opacity 0.65s cubic-bezier(0.22, 1, 0.36, 1),
          transform 0.65s cubic-bezier(0.22, 1, 0.36, 1);
      }
      [data-reveal].reveal-visible {
        opacity: 1;
        transform: none;
      }
      [data-reveal-delay='1'] {
        transition-delay: 0.1s;
      }
      [data-reveal-delay='2'] {
        transition-delay: 0.2s;
      }
      [data-reveal-delay='3'] {
        transition-delay: 0.3s;
      }
      [data-reveal-delay='4'] {
        transition-delay: 0.4s;
      }

      #nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        padding: 0.9rem 0;
        background: rgba(13, 27, 42, 0.85);
        backdrop-filter: blur(16px) saturate(140%);
        -webkit-backdrop-filter: blur(16px) saturate(140%);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 1px 0 rgba(255, 255, 255, 0.03), 0 8px 24px rgba(0, 0, 0, 0.25);
      }

      .nav-link {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 8px 12px;
        font-size: 0.875rem;
        color: rgba(255, 255, 255, 0.65);
        background: transparent;
        border: 0;
        cursor: pointer;
        transition: color 0.18s ease;
      }
      .nav-link:hover {
        color: #fff;
      }
      .nav-link-active {
        color: #fff;
      }
      .nav-link-active::after {
        content: '';
        position: absolute;
        bottom: -4px;
        left: 12px;
        right: 12px;
        height: 2px;
        border-radius: 2px;
        background: #1d9e75;
      }

      .nav-dropdown {
        position: relative;
      }
      .nav-chevron {
        opacity: 0.7;
        transition: transform 0.2s ease;
      }
      .nav-dropdown:hover .nav-chevron,
      .nav-dropdown.is-open .nav-chevron {
        transform: rotate(180deg);
      }
      .nav-dropdown-menu {
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        min-width: 280px;
        background: rgba(13, 27, 42, 0.96);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 6px;
        box-shadow: 0 12px 36px rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        opacity: 0;
        visibility: hidden;
        transform: translateY(-6px);
        transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s;
      }
      .nav-dropdown:hover .nav-dropdown-menu,
      .nav-dropdown:focus-within .nav-dropdown-menu,
      .nav-dropdown.is-open .nav-dropdown-menu {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
      }
      .nav-dropdown-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        border-radius: 8px;
        text-decoration: none;
        transition: background-color 0.15s ease;
      }
      .nav-dropdown-item:hover,
      .nav-dropdown-item:focus-visible {
        background: rgba(255, 255, 255, 0.06);
        outline: none;
      }
      .nav-dropdown-item-active {
        background: rgba(29, 158, 117, 0.1);
      }
      .nav-dropdown-item-active:hover {
        background: rgba(29, 158, 117, 0.16);
      }
    </style>
  </body>
</html>
