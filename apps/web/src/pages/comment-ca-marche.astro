---
// =============================================================================
//  /comment-ca-marche — Expérience scroll-driven plein écran, façon apple.com.
// =============================================================================
//  PASSE 1 (cette passe) : STRUCTURE + SCAFFOLD + hooks data-*. AUCUN JS de
//  motion ici — uniquement la charpente, les ancres et le CSS de fallback
//  (reduced-motion / sans-JS lisible). La PASSE 2 (motion-engineer) câblera la
//  mécanique de scroll.
//
//  ANGLE (passe 0) : bénéfice ÉTABLISSEMENT d'abord. Le geste citoyen est la
//  PREUVE (héros 3D, puis bande récap condensée), pas le sujet. On marque
//  visuellement la bascule « côté usager → côté vous » à l'ACTE 3.
//
//  Séquence narrative (5 actes pleins + 1 transition) :
//    ACTE 0 · Hero plein écran  → <h1> UNIQUE orienté bénéfice + CTA devis.
//    ACTE 1 · Héros 3D          → Immersive3DStory : le geste raconté UNE fois.
//                                 (auto-sticky 300vh interne — NE PAS ré-épingler.)
//    TRANSITION (pas plein écran) → bande récap usager condensée
//                                 « Trouver → Réserver → Ouvrir → Rendre ».
//    ACTE 2 · La borne          → LockerDistributor3D : interactivité + statuts
//                                 temps réel + antivandal/IP54.
//    ACTE 3 · Côté établissement → timeline onboarding 4 étapes + colonne
//                                 épinglée desktop avec CTA « Demander un devis ».
//    ACTE 4 · Tout est inclus   → grille 6 prestations, suivie de FinalCta.
//
//  DOUBLONS retirés (cohérence Apple — un seul récit du geste) :
//    → GARDÉ   Immersive3DStory   (héros, 3D scrollytelling).
//    → GARDÉ   LockerDistributor3D (autre intention : manipuler la borne).
//    → NON MONTÉ  ImmersiveLocker / JourneySimulation (doublons du héros 3D ;
//                 le récap usager survit en TEXTE dans la bande de transition).
//
//  ─────────────────────────────────────────────────────────────────────────
//  TODO — HOOKS à câbler en PASSE 2 (motion-engineer), transform/opacity only,
//  rAF-throttle, listeners passifs, dispose au pagehide, neutralisé sous
//  prefers-reduced-motion :
//    [data-scroll-progress]   → barre de progression globale (scaleX 0→1 via --p).
//    [data-scene-act="0..4"]  → index narratif de chaque acte plein écran.
//    [data-bg-act]            → crossfade de fond inter-actes (couches superposées).
//    [data-parallax="±n"]     → couche décorative translatée (transform Y borné).
//    [data-pin] / [data-pin-inner] → colonne épinglée (ACTE 3) ; sticky CSS de
//                               base déjà posé, à renforcer si besoin.
//    [data-progress]          → mapper la progression de l'acte sur la cadence
//                               des reveals d'étapes (ACTE 3).
//    [data-floating-cta]      → CTA flottant : apparaît après le hero, disparaît
//                               quand FinalCta entre dans le viewport.
//    [data-mobile-cta]        → barre d'action fixe bas mobile (même logique
//                               d'apparition/disparition que le CTA flottant).
//    [data-scroll-hint]       → invite « Défilez » : fondu dès le 1er scroll.
//    [data-reveal]            → DÉJÀ géré par Base.astro (IO + CSS). Ne pas recâbler.
//  ─────────────────────────────────────────────────────────────────────────
//
//  A11y : un seul <h1> (ACTE 0), un <h2> par acte, <ol> pour les étapes. Tout
//  le contenu informatif des moments 3D existe AUSSI en texte (composants à
//  fallback statique). Sous-titres ≥ text-white/75. Cibles ≥ 44px.

import Base from '@/layouts/Base.astro'
import FinalCta from '@/components/FinalCta.astro'
import LockerDistributor3D from '@/components/LockerDistributor3D.astro'
import Immersive3DStory from '@/components/Immersive3DStory.astro'

// --- TRANSITION : récap usager condensé (4 puces, 1 ligne + micro-détail) ----
// Sert aussi de fallback texte lisible du héros 3D (l'ACTE 1).
const recap = [
  { n: '01', label: 'Trouver', desc: 'Le casier libre le plus proche, stock en temps réel.', tech: 'GPS · stock live < 20 ms' },
  { n: '02', label: 'Réserver', desc: 'Une durée (30 / 60 / 90 / 120 min), payée en deux taps.', tech: 'Apple Pay · Google Pay · caution préautorisée' },
  { n: '03', label: 'Ouvrir', desc: 'Scan du QR à la borne, casier ouvert en moins d’une seconde.', tech: 'QR JWT HS256 · NFC · offline 24h' },
  { n: '04', label: 'Rendre', desc: 'Retour dans n’importe quel casier libre du réseau.', tech: 'Rappel push · RFID · multi-points' },
]

// --- ACTE 3 : onboarding établissement (contenu existant conservé) -----------
const onboarding = [
  {
    n: '01',
    title: 'Devis & cadrage',
    duration: '1 semaine',
    desc: "Vous nous envoyez votre demande via le formulaire. On vous rappelle sous 24h pour qualifier le besoin : nombre de distributeurs, sports, emplacements envisagés, budget.",
    deliverables: ['Devis détaillé sous 48h', 'Configuration recommandée', 'Plan de financement (subventions incluses si éligible)'],
  },
  {
    n: '02',
    title: 'Visite technique',
    duration: '1 à 2 semaines',
    desc: "On vient sur place repérer les emplacements : alimentation électrique 230V, couverture 4G, ancrage au sol, signalétique. Validation des plans avec votre service technique.",
    deliverables: ["Plan d'implantation", 'Devis travaux annexes éventuels', 'Convention signée'],
  },
  {
    n: '03',
    title: 'Installation',
    duration: '2 à 3 semaines',
    desc: "On fabrique, on livre, on pose. Le matériel sportif est chargé dans les casiers. Configuration du tenant dans le dashboard. Formation de la personne référente côté établissement.",
    deliverables: ['Distributeurs en service', 'Formation admin (1h)', 'Documentation opérationnelle'],
  },
  {
    n: '04',
    title: 'Lancement & suivi',
    duration: 'Continu',
    desc: "Communication usagers (affichage + push), suivi 30/60/90 jours, ajustement du matériel selon usage observé. Hotline N2 SportLocker disponible 7j/7.",
    deliverables: ['Bilan trimestriel', 'Renouvellement matériel inclus', 'Support technique illimité'],
  },
]

// --- ACTE 4 : ce qu'on fournit (contenu existant conservé) -------------------
const inclus = [
  { icon: '🔒', title: 'Distributeur antivandal', desc: 'Acier inox 2 mm, IP54, plage -10°C à +60°C, conçu pour 10 ans en extérieur.' },
  { icon: '⚽', title: 'Matériel sportif chargé', desc: 'Ballons, raquettes, frisbees, cordes à sauter. Adapté à votre site, renouvelé inclus.' },
  { icon: '📡', title: 'Connectivité 4G + cache', desc: 'Carte SIM M2M incluse. Fonctionnement garanti 24h hors-ligne.' },
  { icon: '🛠️', title: 'Maintenance N1 + N2', desc: 'Vous gérez les petits incidents (recharge matériel). On gère le reste à distance ou en intervention.' },
  { icon: '📊', title: 'Dashboard temps réel', desc: "Stats d'usage, alertes maintenance, force-cancel réservations abusives." },
  { icon: '🆙', title: 'Mises à jour OTA', desc: 'Firmware mis à jour à distance via Balena. Aucune intervention sur site.' },
]
---

<Base
  title="Comment ça marche — le sport en libre-service sur vos terrains"
  description="Le sport en libre-service sur vos terrains, sans rien à gérer : matériel, maintenance et support inclus. L'usager emprunte en 30 secondes ; vous mettez en service en 4 à 6 semaines."
>
  <!-- ====================================================================== -->
  <!-- Barre de progression globale (acte courant / total).                   -->
  <!-- PASSE 2 : piloter --p (scaleX 0→1) selon la progression de page.        -->
  <!-- ====================================================================== -->
  <div id="ccm-progress" class="ccm-progress" data-scroll-progress aria-hidden="true">
    <span class="ccm-progress-bar"></span>
  </div>

  <!-- ====================================================================== -->
  <!-- FOND CINÉMATIQUE — 2 couches fixes superposées, crossfade par OPACITY   -->
  <!-- (jamais d'animation de background-color). Pilotées par l'acte le plus   -->
  <!-- visible (IntersectionObserver). Décoratif, navy cohérent, derrière main.-->
  <!-- ====================================================================== -->
  <div class="ccm-bg" aria-hidden="true">
    <span class="ccm-bg-layer ccm-bg-a" data-bg-layer="a"></span>
    <span class="ccm-bg-layer ccm-bg-b" data-bg-layer="b"></span>
  </div>

  <!-- ====================================================================== -->
  <!-- ACTE 0 · HERO — plein écran, <h1> UNIQUE, bénéfice établissement.       -->
  <!-- ====================================================================== -->
  <section
    class="ccm-act relative min-h-screen flex items-center overflow-hidden"
    data-scene-act="0"
    data-bg-act="hero"
  >
    <div class="absolute inset-0 bg-hero-glow" aria-hidden="true"></div>
    <!-- Couche décorative parallax (PASSE 2 : translateY léger au scroll). -->
    <div class="ccm-orb" data-parallax="-2" aria-hidden="true"></div>

    <div class="container-x relative w-full pt-28 pb-28 sm:pt-32 text-center">
      <span class="eyebrow" data-reveal>Comment ça marche</span>
      <h1
        class="font-extrabold text-display-xl text-white mt-4 mb-6 mx-auto max-w-4xl"
        data-reveal
        data-reveal-delay="1"
      >
        Le sport en libre-service<br class="hidden sm:block" /> sur vos terrains.
        <span class="text-brand-400">Vous ne gérez rien.</span>
      </h1>
      <p
        class="text-[1.15rem] text-white/75 leading-loose max-w-2xl mx-auto font-light"
        data-reveal
        data-reveal-delay="2"
      >
        L'usager emprunte en 30 secondes. Vous mettez en service en 4 à 6 semaines.
        Matériel, maintenance et support : tout est inclus.
      </p>
      <div class="mt-9 flex flex-wrap gap-3 justify-center items-center" data-reveal data-reveal-delay="3">
        <a href="/contact#formulaire" class="btn btn-primary">Demander un devis</a>
        <a href="/tarifs" class="btn btn-outline">Voir les tarifs</a>
      </div>
    </div>

    <!-- Invite de défilement (PASSE 2 : fondu dès le 1er scroll). -->
    <div
      class="ccm-scroll-hint absolute left-1/2 bottom-7 -translate-x-1/2 flex flex-col items-center gap-1 text-white/60 text-xs uppercase tracking-[0.14em]"
      data-scroll-hint
      aria-hidden="true"
    >
      <span>Défilez</span>
      <span class="text-base leading-none">↓</span>
    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- ACTE 1 · LE GESTE (3D) — héros produit app→scan→casier (raconté 1 fois).-->
  <!-- Immersive3DStory gère SON PROPRE sticky (300vh interne) + fallback :     -->
  <!-- on ne l'enveloppe donc PAS dans un data-pin.                            -->
  <!-- ====================================================================== -->
  <section
    id="geste"
    class="ccm-act bg-navy-800 scroll-mt-20"
    data-scene-act="1"
    data-bg-act="navy-800"
  >
    <div class="container-x pt-24 sm:pt-28">
      <div class="mb-2 max-w-2xl">
        <span class="tag tag-brand mb-4 inline-block" data-reveal>La preuve, côté usager</span>
        <h2 class="section-title" data-reveal data-reveal-delay="1">
          Du téléphone<br class="hidden sm:block" /> au casier ouvert.
        </h2>
        <p class="section-sub !text-white/75 mt-4" data-reveal data-reveal-delay="2">
          Faites défiler : la caméra voyage de votre téléphone jusqu'à la borne, suit le scan
          du QR code, puis fait le tour du distributeur. Un seul geste, raconté une fois — pour
          montrer ce que vivront les usagers de vos terrains.
        </p>
      </div>
    </div>
    <!-- HÉROS PRODUIT : scène 3D scrollytelling (auto-sticky, lazy, a11y OK). -->
    <Immersive3DStory />
  </section>

  <!-- ====================================================================== -->
  <!-- TRANSITION · RÉCAP USAGER CONDENSÉ — bande horizontale (PAS plein       -->
  <!-- écran). 4 puces « Trouver → Réserver → Ouvrir → Rendre ». Sert aussi de  -->
  <!-- fallback texte lisible du héros 3D ci-dessus.                           -->
  <!-- ====================================================================== -->
  <section
    id="recap-usager"
    class="ccm-recap bg-navy-800 scroll-mt-20 pb-20 sm:pb-24"
    aria-labelledby="recap-title"
  >
    <div class="container-x">
      <p id="recap-title" class="text-sm text-white/75 font-light text-center mb-8 max-w-2xl mx-auto" data-reveal>
        En clair, côté usager : <span class="text-white">trouver, réserver, ouvrir, rendre</span> — sans guichet ni dépôt de papiers.
      </p>
      <ol class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-px bg-white/10 rounded-xl overflow-hidden border border-white/10">
        {recap.map((s, i) => (
          <li class="bg-navy-800 p-5 sm:p-6" data-reveal data-reveal-delay={String((i % 4) + 1)}>
            <div class="flex items-center gap-3 mb-2">
              <span class="font-extrabold text-2xl text-brand-400 leading-none">{s.n}</span>
              <span class="font-bold text-white text-base">{s.label}</span>
              {i < recap.length - 1 && (
                <span class="hidden lg:inline text-white/30 ml-auto text-lg leading-none" aria-hidden="true">→</span>
              )}
            </div>
            <p class="text-sm text-white/75 font-light leading-relaxed">{s.desc}</p>
            <p class="mt-3 text-[0.7rem] text-brand-400 uppercase tracking-wider">{s.tech}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- ACTE 2 · LA BORNE INSTALLÉE SUR VOS SITES — interactif (LockerDistributor3D).-->
  <!-- Angle : interactivité + statuts temps réel + antivandal/IP54.           -->
  <!-- (On NE re-décrit PAS les composants un par un : le héros l'a déjà fait.) -->
  <!-- ====================================================================== -->
  <section
    id="distributeur-3d"
    class="ccm-act bg-navy-900 scroll-mt-20 py-24 sm:py-28 min-h-screen flex flex-col justify-center"
    data-scene-act="2"
    data-bg-act="navy-900"
  >
    <div class="container-x">
      <div class="mb-10 max-w-3xl">
        <span class="tag tag-brand mb-4 inline-block" data-reveal>Côté terrain</span>
        <h2 class="section-title" data-reveal data-reveal-delay="1">
          La borne installée<br class="hidden sm:block" /> sur vos sites.
        </h2>
        <p class="section-sub !text-white/75 mt-4" data-reveal data-reveal-delay="2">
          Manipulez-la : faites-la pivoter, ouvrez les portes, lisez les statuts en temps réel —
          libre, réservé, emprunté, maintenance. Les boutons sous la scène pilotent tout au clavier
          (rotation, ouverture des portes, étiquettes, réinitialisation). Coque acier antivandale
          IP54, conçue pour rester dehors toute l'année.
        </p>
      </div>

      <div data-reveal data-reveal-delay="3">
        <LockerDistributor3D />
      </div>
    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- BASCULE · « côté usager → côté vous » — marqueur visuel de transition.  -->
  <!-- ====================================================================== -->
  <div class="bg-navy-900" aria-hidden="true">
    <div class="container-x">
      <div class="ccm-switch" data-reveal>
        <span class="ccm-switch-from">Côté usager</span>
        <span class="ccm-switch-arrow">→</span>
        <span class="ccm-switch-to">Côté vous</span>
      </div>
    </div>
  </div>

  <!-- ====================================================================== -->
  <!-- ACTE 3 · CÔTÉ ÉTABLISSEMENT — colonne épinglée + timeline onboarding.    -->
  <!-- CTA « Demander un devis » dans la colonne épinglée (desktop).           -->
  <!-- ====================================================================== -->
  <section
    id="installation"
    class="ccm-act bg-navy-900 scroll-mt-20 pb-24 sm:pb-28 pt-4"
    data-scene-act="3"
    data-bg-act="navy-900"
    data-progress
  >
    <div class="container-x">
      <div class="grid lg:grid-cols-[0.9fr_1.1fr] gap-12 lg:gap-16 items-start">
        <!-- Colonne épinglée (desktop). PASSE 2 : renforcer via data-pin-inner. -->
        <div class="ccm-pin" data-pin>
          <div class="ccm-pin-inner lg:sticky lg:top-28" data-pin-inner>
            <span class="tag tag-brand mb-4 inline-block" data-reveal>Côté établissement</span>
            <h2 class="section-title" data-reveal data-reveal-delay="1">
              De la demande à la mise<br class="hidden sm:block" /> en service en 4 à 6 semaines.
            </h2>
            <p class="section-sub !text-white/75 mt-5" data-reveal data-reveal-delay="2">
              Un parcours clé en main. Vous n'avez à gérer ni l'achat de matériel, ni la
              maintenance, ni le support N2.
            </p>
            <a
              href="/contact#formulaire"
              class="btn btn-primary mt-8"
              data-reveal
              data-reveal-delay="3"
            >
              Demander un devis
            </a>
          </div>
        </div>

        <!-- Timeline onboarding : 4 étapes révélées une à une au scroll. -->
        <ol class="ccm-steps flex flex-col gap-5">
          {onboarding.map((step, i) => (
            <li
              class="card-dark p-7 sm:p-8"
              data-reveal
              data-reveal-delay={String((i % 4) + 1)}
              data-step={String(i)}
            >
              <div class="flex items-start justify-between mb-5">
                <div class="font-extrabold text-5xl text-brand-400 leading-none">{step.n}</div>
                <span class="tag tag-white text-[0.65rem]">{step.duration}</span>
              </div>
              <h3 class="font-extrabold text-white text-xl mb-3">{step.title}</h3>
              <p class="text-sm text-white/75 font-light leading-relaxed mb-5">{step.desc}</p>
              <div class="text-[0.7rem] uppercase tracking-wider text-white/60 mb-3">Livrables</div>
              <ul class="space-y-2">
                {step.deliverables.map((d) => (
                  <li class="flex items-start gap-2.5 text-sm text-white/75">
                    <span class="text-brand-400 mt-1 shrink-0">✓</span>
                    <span class="font-light">{d}</span>
                  </li>
                ))}
              </ul>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- ====================================================================== -->
  <!-- ACTE 4 · TOUT EST INCLUS — grille des prestations, suivie de FinalCta.   -->
  <!-- ====================================================================== -->
  <section
    class="ccm-act bg-navy-800 py-24 sm:py-28"
    data-scene-act="4"
    data-bg-act="navy-800"
  >
    <div class="container-x">
      <div class="text-center mb-14 max-w-2xl mx-auto">
        <span class="eyebrow" data-reveal>Tout est inclus</span>
        <h2 class="section-title mt-3" data-reveal data-reveal-delay="1">
          Aucun coût caché, aucune surprise.
        </h2>
        <p class="section-sub !text-white/75 mt-4 mx-auto text-center" data-reveal data-reveal-delay="2">
          Pas de renouvellement matériel à anticiper. Pas de coût d'intervention.
          Une mensualité, et c'est tout.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {inclus.map((f, i) => (
          <div class="card-dark p-6" data-reveal data-reveal-delay={String((i % 3) + 1)}>
            <div class="w-11 h-11 rounded-lg bg-brand-500/10 border border-brand-500/30 grid place-items-center text-xl mb-4" aria-hidden="true">
              {f.icon}
            </div>
            <h3 class="font-bold text-white text-base mb-2">{f.title}</h3>
            <p class="text-sm text-white/75 font-light leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- OUTRO · CTA final (cible la fin de page : masque le CTA flottant). -->
  <div id="ccm-final-cta">
    <FinalCta
      title="Prêt à voir si SportLocker fonctionne pour vous ?"
      sub="Un appel de 15 minutes suffit pour valider la faisabilité, le timing et le budget."
      primary={{ href: '/contact#formulaire', label: 'Demander un devis' }}
      secondary={{ href: '/tarifs', label: 'Voir les tarifs' }}
    />
  </div>

  <!-- ====================================================================== -->
  <!-- CTA FLOTTANT (desktop / tablette) — apparaît après le hero, disparaît   -->
  <!-- quand FinalCta entre dans le viewport. PASSE 2 pilote l'apparition.     -->
  <!-- État de repos = masqué (opacity:0, translateY) jusqu'au câblage motion. -->
  <!-- ====================================================================== -->
  <a
    href="/contact#formulaire"
    class="ccm-floating-cta btn btn-primary"
    data-floating-cta
  >
    Demander un devis
  </a>

  <!-- ====================================================================== -->
  <!-- BARRE D'ACTION FIXE BAS (mobile) — hauteur ≥ 56px, cible tactile ≥ 44px. -->
  <!-- Même logique d'apparition/disparition que le CTA flottant (PASSE 2).    -->
  <!-- ====================================================================== -->
  <div class="ccm-mobile-cta" data-mobile-cta>
    <a href="/tarifs" class="btn btn-outline flex-1">Tarifs</a>
    <a href="/contact#formulaire" class="btn btn-primary flex-[1.4]">Demander un devis</a>
  </div>

  <!-- ====================================================================== -->
  <!-- PASSE 2 — MÉCANIQUE SCROLL. transform/opacity only, rAF-throttle,       -->
  <!-- listeners passifs, IO pour les actes, dispose au pagehide. Neutralisé   -->
  <!-- sous prefers-reduced-motion (état lisible laissé en place avant return).-->
  <!-- ====================================================================== -->
  <script is:inline>
    (function () {
      var doc = document

      // --- Hooks -------------------------------------------------------------
      var progressBar = doc.querySelector('[data-scroll-progress]')
      var parallaxEls = [].slice.call(doc.querySelectorAll('[data-parallax]'))
      var bgA = doc.querySelector('[data-bg-layer="a"]')
      var bgB = doc.querySelector('[data-bg-layer="b"]')
      var sceneActs = [].slice.call(doc.querySelectorAll('[data-scene-act]'))
      var floatingCta = doc.querySelector('[data-floating-cta]')
      var mobileCta = doc.querySelector('[data-mobile-cta]')
      var scrollHint = doc.querySelector('[data-scroll-hint]')
      var heroAct = doc.querySelector('[data-scene-act="0"]')
      var finalCta = doc.getElementById('ccm-final-cta')

      var reduced =
        window.matchMedia &&
        window.matchMedia('(prefers-reduced-motion: reduce)').matches

      // ---------------------------------------------------------------------
      //  prefers-reduced-motion : on laisse un état LISIBLE et FONCTIONNEL puis
      //  on sort. La barre est masquée par CSS, le parallax figé, le fond fixé
      //  sur la couche A, le hint visible, et les CTA flottant/mobile rendus
      //  visibles immédiatement (sans glissement) pour rester convertissants.
      // ---------------------------------------------------------------------
      if (reduced) {
        if (progressBar) progressBar.style.display = 'none'
        showCta(floatingCta, true)
        showCta(mobileCta, true)
        if (scrollHint) scrollHint.style.opacity = '1'
        return
      }

      // --- Helpers -----------------------------------------------------------
      var mqMobile = window.matchMedia('(max-width: 767px)')

      function clamp(v, lo, hi) {
        return v < lo ? lo : v > hi ? hi : v
      }

      // Affiche/masque un CTA. Sous mouvement réduit, applique directement
      // l'état final sans transition (la transition CSS est déjà neutralisée).
      function showCta(el, visible) {
        if (!el) return
        if (visible) {
          el.style.opacity = '1'
          el.style.transform = 'translateY(0)'
          el.style.pointerEvents = 'auto'
        } else {
          el.style.opacity = '0'
          el.style.pointerEvents = 'none'
          // translateY de repos déjà porté par le CSS (16px / 100%)
          el.style.transform = ''
        }
      }

      // ====================================================================
      //  1) Barre de progression + 2) parallax + 5) hint — lus dans un seul
      //     passage rAF-throttlé (un read scroll, écritures transform/opacity).
      // ====================================================================
      var ticking = false
      var lastScroll = 0
      var winH = window.innerHeight

      function applyScroll() {
        ticking = false
        var y = lastScroll
        var maxScroll =
          (doc.documentElement.scrollHeight || doc.body.scrollHeight) - winH
        var p = maxScroll > 0 ? clamp(y / maxScroll, 0, 1) : 0

        // 1) progression globale → scaleX via --p
        if (progressBar) progressBar.style.setProperty('--p', String(p))

        // 2) parallax (off mobile) : translate3d borné, transform only
        if (!mqMobile.matches) {
          for (var i = 0; i < parallaxEls.length; i++) {
            var el = parallaxEls[i]
            var factor = parseFloat(el.getAttribute('data-parallax')) || 0
            // facteur "-2" → ~ -0.06 px/px, borné à ±80px pour rester sobre
            var offset = clamp((y * factor) / 32, -80, 80)
            el.style.transform = 'translate3d(0,' + offset + 'px,0)'
          }
        }

        // 5) indice de scroll : fondu au-delà de ~12% de viewport
        if (scrollHint) {
          var hintOpacity = clamp(1 - y / (winH * 0.12), 0, 1)
          scrollHint.style.opacity = String(hintOpacity)
        }
      }

      function onScroll() {
        lastScroll = window.pageYOffset || doc.documentElement.scrollTop || 0
        if (!ticking) {
          ticking = true
          requestAnimationFrame(applyScroll)
        }
      }

      function onResize() {
        winH = window.innerHeight
        // parallax figé sur mobile : on remet les couches à plat
        if (mqMobile.matches) {
          for (var i = 0; i < parallaxEls.length; i++) {
            parallaxEls[i].style.transform = ''
          }
        }
        onScroll()
      }

      // ====================================================================
      //  3) Crossfade de fond inter-actes — opacity de 2 couches superposées,
      //     pilotée par l'acte le plus visible (IntersectionObserver).
      //     Actes 0 (hero) & 1 (geste, navy-800) → couche A.
      //     Actes 2/3/4 (borne, établissement, navy-900) → couche B.
      // ====================================================================
      var bgIo = null
      var ratios = {}
      function updateBg() {
        if (!bgA || !bgB) return
        var best = -1
        var bestAct = 0
        for (var key in ratios) {
          if (ratios[key] > best) {
            best = ratios[key]
            bestAct = parseInt(key, 10)
          }
        }
        var toB = bestAct >= 2
        bgA.style.opacity = toB ? '0' : '1'
        bgB.style.opacity = toB ? '1' : '0'
      }
      if (bgA && bgB && sceneActs.length) {
        bgIo = new IntersectionObserver(
          function (entries) {
            for (var i = 0; i < entries.length; i++) {
              var e = entries[i]
              var act = e.target.getAttribute('data-scene-act')
              ratios[act] = e.isIntersecting ? e.intersectionRatio : 0
            }
            updateBg()
          },
          { threshold: [0, 0.25, 0.5, 0.75, 1] },
        )
        for (var s = 0; s < sceneActs.length; s++) bgIo.observe(sceneActs[s])
        // état initial : couche A (haut de page)
        bgA.style.opacity = '1'
      }

      // ====================================================================
      //  4) CTA flottant + barre mobile — apparaissent une fois le hero passé,
      //     disparaissent quand #ccm-final-cta entre dans le viewport.
      // ====================================================================
      var heroPassed = false
      var finalInView = false

      function syncCtas() {
        var show = heroPassed && !finalInView
        if (!mqMobile.matches) {
          showCta(floatingCta, show)
          showCta(mobileCta, false) // barre mobile cachée par CSS en desktop
        } else {
          showCta(mobileCta, show)
          showCta(floatingCta, false)
        }
      }

      var heroIo = null
      if (heroAct) {
        heroIo = new IntersectionObserver(
          function (entries) {
            // hero "passé" = plus du tout intersecté
            heroPassed = !entries[0].isIntersecting
            syncCtas()
          },
          { threshold: 0 },
        )
        heroIo.observe(heroAct)
      }

      var finalIo = null
      if (finalCta) {
        finalIo = new IntersectionObserver(
          function (entries) {
            finalInView = entries[0].isIntersecting
            syncCtas()
          },
          { threshold: 0 },
        )
        finalIo.observe(finalCta)
      }

      // bascule desktop/mobile : resynchronise la cible visible
      function onMqChange() {
        syncCtas()
        onResize()
      }
      if (mqMobile.addEventListener) {
        mqMobile.addEventListener('change', onMqChange)
      } else if (mqMobile.addListener) {
        mqMobile.addListener(onMqChange)
      }

      // --- Démarrage ---------------------------------------------------------
      window.addEventListener('scroll', onScroll, { passive: true })
      window.addEventListener('resize', onResize, { passive: true })
      onScroll() // état initial (barre/hint/parallax)
      syncCtas()

      // ====================================================================
      //  Cleanup : retire les listeners, déconnecte les IO, annule le rAF en
      //  vol et purge les will-change posés pour le scroll. Sur pagehide.
      // ====================================================================
      function dispose() {
        window.removeEventListener('scroll', onScroll)
        window.removeEventListener('resize', onResize)
        if (mqMobile.removeEventListener) {
          mqMobile.removeEventListener('change', onMqChange)
        } else if (mqMobile.removeListener) {
          mqMobile.removeListener(onMqChange)
        }
        if (bgIo) bgIo.disconnect()
        if (heroIo) heroIo.disconnect()
        if (finalIo) finalIo.disconnect()
        // retire les will-change (plus d'animation après démontage)
        var wc = parallaxEls.slice()
        if (progressBar) {
          var pb = progressBar.querySelector('.ccm-progress-bar')
          if (pb) wc.push(pb)
        }
        if (bgA) wc.push(bgA)
        if (bgB) wc.push(bgB)
        for (var i = 0; i < wc.length; i++) wc[i].style.willChange = 'auto'
      }
      window.addEventListener('pagehide', dispose)
    })()
  </script>

  <style>
    /* =====================================================================
       PASSE 1 — styles de CHARPENTE + état de repos des hooks motion.
       La PASSE 2 (motion-engineer) pilotera l'apparition (transform/opacity).
       ===================================================================== */

    /* Barre de progression globale, fixée en haut sous la nav.
       PASSE 2 : piloter --p (0→1) → scaleX de la barre. */
    .ccm-progress {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      z-index: 90;
      pointer-events: none;
      background: rgba(255, 255, 255, 0.06);
    }
    .ccm-progress-bar {
      display: block;
      height: 100%;
      width: 100%;
      transform: scaleX(var(--p, 0));
      transform-origin: 0 50%;
      background: #1d9e75;
      will-change: transform;
    }

    /* Fond cinématique : 2 couches fixes plein écran, crossfade en OPACITY
       (jamais d'animation de background-color). Passe d'étalonnage façon
       « color-grade » par acte : overlay TRÈS léger (alpha bornée), au-dessus
       du fond solide des sections mais pointer-events:none, et d'intensité
       faible pour ne jamais nuire à la lisibilité du texte. */
    .ccm-bg {
      position: fixed;
      inset: 0;
      z-index: 5;
      pointer-events: none;
      mix-blend-mode: screen;
    }
    .ccm-bg-layer {
      position: absolute;
      inset: 0;
      display: block;
      opacity: 0;
      will-change: opacity;
      transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    }
    /* Couche A : ambiance « côté usager » — halo brand diffus en haut/droite. */
    .ccm-bg-a {
      background:
        radial-gradient(130% 90% at 78% -5%, rgba(29, 158, 117, 0.12), rgba(29, 158, 117, 0) 55%),
        radial-gradient(90% 70% at 15% 100%, rgba(43, 194, 149, 0.05), rgba(43, 194, 149, 0) 60%);
    }
    /* Couche B : ambiance « côté vous » — halo plus profond, ancré bas/gauche. */
    .ccm-bg-b {
      background:
        radial-gradient(120% 80% at 18% 108%, rgba(29, 158, 117, 0.1), rgba(29, 158, 117, 0) 55%),
        radial-gradient(80% 60% at 90% 0%, rgba(15, 120, 90, 0.06), rgba(15, 120, 90, 0) 60%);
    }
    /* Le contenu des actes reste au-dessus du wash : le texte n'est jamais
       teinté (overlay screen à alpha faible = lueur ambiante, pas un voile). */
    .ccm-act,
    .ccm-recap {
      position: relative;
      z-index: 10;
    }

    /* Orbe décorative de l'ouverture (couche parallax). Bornée pour ne jamais
       provoquer de scroll horizontal (la section est overflow-hidden). */
    .ccm-orb {
      position: absolute;
      top: 18%;
      right: -6rem;
      width: 22rem;
      height: 22rem;
      max-width: 60vw;
      border-radius: 9999px;
      background: radial-gradient(
        circle at 50% 50%,
        rgba(29, 158, 117, 0.16),
        rgba(29, 158, 117, 0) 70%
      );
      filter: blur(8px);
      will-change: transform;
    }

    /* Invite de défilement : flottement doux (figé sous mouvement réduit). */
    .ccm-scroll-hint {
      animation: ccm-bob 2.4s ease-in-out infinite;
    }
    @keyframes ccm-bob {
      0%,
      100% {
        transform: translate(-50%, 0);
      }
      50% {
        transform: translate(-50%, 6px);
      }
    }

    /* La colonne épinglée s'accroche pendant le défilement des étapes voisines.
       Sur mobile, pas de sticky : la colonne reprend sa place dans le flux. */
    .ccm-pin-inner {
      will-change: transform;
    }

    /* Marqueur de bascule « côté usager → côté vous » : trait fin centré. */
    .ccm-switch {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.85rem;
      padding: 2.75rem 0;
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
    }
    .ccm-switch-from {
      color: rgba(255, 255, 255, 0.4);
    }
    .ccm-switch-arrow {
      color: #1d9e75;
      font-size: 1rem;
      line-height: 1;
    }
    .ccm-switch-to {
      color: #fff;
      font-weight: 600;
    }

    /* CTA flottant (desktop / tablette) : ancré bas-droite, masqué au repos.
       PASSE 2 fera glisser opacity 0→1 + translateY après le hero, et le
       masquera quand FinalCta entre en vue. Caché sous 768px (barre mobile). */
    .ccm-floating-cta {
      position: fixed;
      right: 1.5rem;
      bottom: 1.5rem;
      z-index: 80;
      box-shadow: 0 18px 40px -16px rgba(0, 0, 0, 0.55);
      opacity: 0;
      transform: translateY(16px);
      pointer-events: none;
      transition:
        opacity 0.35s cubic-bezier(0.16, 1, 0.3, 1),
        transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    }
    @media (max-width: 767px) {
      .ccm-floating-cta {
        display: none;
      }
    }

    /* Barre d'action fixe (mobile) : pleine largeur en bas, ≥ 56px de haut,
       cibles tactiles ≥ 44px (les .btn font py-3.5 ≈ 48px). Masquée au repos. */
    .ccm-mobile-cta {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 80;
      display: flex;
      gap: 0.5rem;
      padding: 0.625rem 1rem calc(0.625rem + env(safe-area-inset-bottom, 0px));
      min-height: 56px;
      background: rgba(11, 22, 34, 0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      opacity: 0;
      transform: translateY(100%);
      pointer-events: none;
      transition:
        opacity 0.3s ease,
        transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .ccm-mobile-cta .btn {
      padding-top: 0.75rem;
      padding-bottom: 0.75rem;
    }
    @media (min-width: 768px) {
      .ccm-mobile-cta {
        display: none;
      }
    }

    /* =====================================================================
       prefers-reduced-motion ET fallback sans-JS : la page reste 100%
       lisible. Sticky neutralisé, orbe/flottements figés, barre masquée.
       Les CTA flottant/mobile restent au repos (masqués) tant que la PASSE 2
       n'a pas câblé leur logique d'apparition — la conversion passe par les
       CTA en flux (hero, ACTE 3, FinalCta), tous toujours visibles.
       ===================================================================== */
    @media (prefers-reduced-motion: reduce) {
      .ccm-pin-inner {
        position: static !important;
        top: auto !important;
      }
      .ccm-scroll-hint {
        animation: none;
      }
      .ccm-orb {
        transform: none !important;
      }
      .ccm-progress {
        display: none;
      }
      /* Fond cinématique figé : une seule couche douce, sans crossfade. */
      .ccm-bg-layer {
        transition: none;
      }
      .ccm-bg-a {
        opacity: 1;
      }
      .ccm-bg-b {
        opacity: 0;
      }
      /* CTA flottant + barre mobile visibles d'emblée, sans glissement. */
      .ccm-floating-cta,
      .ccm-mobile-cta {
        opacity: 1 !important;
        transform: none !important;
        pointer-events: auto !important;
        transition: none !important;
      }
      .ccm-scroll-hint {
        opacity: 1 !important;
      }
    }
  </style>
