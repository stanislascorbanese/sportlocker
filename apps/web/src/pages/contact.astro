---
import Base from '@/layouts/Base.astro'
import ContactForm from '@/components/ContactForm.astro'
import { SITE } from '@/data/site'
---

<Base
  title="Demander un devis"
  description="Envoyez-nous votre demande de devis SportLocker. Réponse sous 24h ouvrées avec un appel de qualification de 15 minutes."
  noindex={false}
>
  <section class="pt-32 pb-20 sm:pt-40 relative overflow-hidden min-h-screen">
    <div class="absolute inset-0 bg-hero-glow" aria-hidden="true"></div>
    <div class="container-x relative">
      <div class="grid lg:grid-cols-[1fr_1.4fr] gap-12 lg:gap-16 items-start">
        <!-- Pitch latéral -->
        <div class="lg:sticky lg:top-32">
          <span class="tag tag-brand inline-block mb-6" data-reveal>Contact</span>
          <h1 class="font-extrabold text-display-xl text-white mb-6" data-reveal data-reveal-delay="1">
            Parlons<br/>
            <span class="text-brand-400">de votre projet.</span>
          </h1>
          <p class="text-white/65 leading-relaxed font-light mb-9" data-reveal data-reveal-delay="2">
            Décrivez-nous votre site, vos objectifs et votre timing. On revient sous 24h ouvrées
            avec un devis de cadrage et, si pertinent, une proposition de visite sur place.
          </p>

          <div class="space-y-5 text-sm" data-reveal data-reveal-delay="3">
            <div class="flex gap-3 items-start">
              <span class="text-brand-400 mt-0.5 text-base">⏱</span>
              <div>
                <div class="font-medium text-white mb-0.5">Réponse sous 24h ouvrées</div>
                <div class="text-white/60 font-light">Par email + appel court si pertinent.</div>
              </div>
            </div>
            <div class="flex gap-3 items-start">
              <span class="text-brand-400 mt-0.5 text-base">📋</span>
              <div>
                <div class="font-medium text-white mb-0.5">Devis sans engagement</div>
                <div class="text-white/60 font-light">Aucune obligation, aucune relance pénible.</div>
              </div>
            </div>
            <div class="flex gap-3 items-start">
              <span class="text-brand-400 mt-0.5 text-base">📍</span>
              <div>
                <div class="font-medium text-white mb-0.5">Visite de site offerte</div>
                <div class="text-white/60 font-light">Loire-Atlantique &amp; Vendée prioritaires. Ailleurs : visioconférence ou déplacement sur devis.</div>
              </div>
            </div>
            <div class="flex gap-3 items-start">
              <span class="text-brand-400 mt-0.5 text-base">✉</span>
              <div>
                <div class="font-medium text-white mb-0.5">Préférez l'email direct ?</div>
                <a href={`mailto:${SITE.email}`} class="text-brand-400 hover:underline font-medium">{SITE.email}</a>
              </div>
            </div>
          </div>
        </div>

        <div id="formulaire" class="scroll-mt-28">
          <ContactForm />
        </div>
      </div>
    </div>
  </section>
</Base>
