---
import Base from '@/layouts/Base.astro'
import { SITE } from '@/data/site'

// Public token Web3Forms côté front : lu depuis l'env build-time, fallback vide.
// Côté Astro on injecte via import.meta.env (build).
const WEB3FORMS_KEY = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? ''
---

<Base
  title="Demander un devis"
  description="Envoyez-nous votre demande de devis SportLocker. Réponse sous 24h ouvrées avec un appel de qualification de 15 minutes."
  noindex={false}
>
  <section class="pt-32 pb-20 sm:pt-40 relative overflow-hidden min-h-screen">
    <div class="absolute inset-0 bg-hero-glow" aria-hidden="true"></div>
    <div class="container-x relative">
      <div class="grid lg:grid-cols-[1fr_1.4fr] gap-12 lg:gap-16 items-start">
        <!-- Pitch latéral -->
        <div class="lg:sticky lg:top-32">
          <span class="tag tag-green inline-block mb-6" data-reveal>Contact</span>
          <h1 class="font-extrabold text-display-xl text-white mb-6" data-reveal data-reveal-delay="1">
            Parlons<br/>
            <span class="text-brand-500">de votre projet.</span>
          </h1>
          <p class="text-white/65 leading-relaxed font-light mb-9" data-reveal data-reveal-delay="2">
            Décrivez-nous votre site, vos objectifs et votre timing. On revient sous 24h ouvrées
            avec un devis de cadrage et, si pertinent, une proposition de visite sur place.
          </p>

          <div class="space-y-5 text-sm" data-reveal data-reveal-delay="3">
            <div class="flex gap-3 items-start">
              <span class="text-brand-500 mt-0.5 text-base">⏱</span>
              <div>
                <div class="font-medium text-white mb-0.5">Réponse sous 24h ouvrées</div>
                <div class="text-white/50 font-light">Par email + appel court si pertinent.</div>
              </div>
            </div>
            <div class="flex gap-3 items-start">
              <span class="text-brand-500 mt-0.5 text-base">📋</span>
              <div>
                <div class="font-medium text-white mb-0.5">Devis sans engagement</div>
                <div class="text-white/50 font-light">Aucune obligation, aucune relance pénible.</div>
              </div>
            </div>
            <div class="flex gap-3 items-start">
              <span class="text-brand-500 mt-0.5 text-base">📍</span>
              <div>
                <div class="font-medium text-white mb-0.5">Visite de site offerte</div>
                <div class="text-white/50 font-light">Île-de-France et région proche. Ailleurs : visioconférence en attendant le pilote.</div>
              </div>
            </div>
            <div class="flex gap-3 items-start">
              <span class="text-brand-500 mt-0.5 text-base">✉</span>
              <div>
                <div class="font-medium text-white mb-0.5">Préférez l'email direct ?</div>
                <a href={`mailto:${SITE.email}`} class="text-brand-500 hover:underline font-medium">{SITE.email}</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Formulaire -->
        <div class="card-dark p-7 sm:p-10" data-reveal data-reveal-delay="1">
          <form id="contact-form" class="space-y-5">
            <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
            <input type="hidden" name="subject" value="Nouvelle demande de devis SportLocker" />
            <input type="hidden" name="from_name" value="SportLocker — site vitrine" />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="organization" class="block text-xs uppercase tracking-[0.1em] text-white/50 mb-2">
                  Nom de votre organisation <span class="text-brand-500">*</span>
                </label>
                <input
                  required
                  id="organization"
                  name="organization"
                  type="text"
                  autocomplete="organization"
                  class="w-full bg-black/30 border border-white/10 rounded-lg px-4 py-3 text-white placeholder:text-white/30 focus:border-brand-500 focus:outline-none focus:bg-black/40 transition-colors"
                  placeholder="Mairie de Saint-Exemple, Camping Les Pins…"
                />
              </div>
              <div>
                <label for="locality" class="block text-xs uppercase tracking-[0.1em] text-white/50 mb-2">
                  Localité + département <span class="text-brand-500">*</span>
                </label>
                <input
                  required
                  id="locality"
                  name="locality"
                  type="text"
                  autocomplete="address-level2"
                  class="w-full bg-black/30 border border-white/10 rounded-lg px-4 py-3 text-white placeholder:text-white/30 focus:border-brand-500 focus:outline-none focus:bg-black/40 transition-colors"
                  placeholder="Saint-Exemple (77)"
                />
              </div>
            </div>

            <fieldset>
              <legend class="block text-xs uppercase tracking-[0.1em] text-white/50 mb-3">
                Type d'établissement <span class="text-brand-500">*</span>
              </legend>
              <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
                {['Mairie', 'Camping', 'Hôtel', 'Autre'].map((label, i) => (
                  <label class="relative cursor-pointer">
                    <input
                      required={i === 0}
                      type="radio"
                      name="type"
                      value={label}
                      class="peer sr-only"
                    />
                    <div class="px-3 py-3 text-center text-sm bg-black/20 border border-white/10 rounded-lg text-white/65 hover:border-white/30 peer-checked:border-brand-500 peer-checked:bg-brand-500/10 peer-checked:text-white transition-colors">
                      {label}
                    </div>
                  </label>
                ))}
              </div>
            </fieldset>

            <div>
              <label for="distributors" class="block text-xs uppercase tracking-[0.1em] text-white/50 mb-2">
                Nombre estimé de distributeurs
              </label>
              <select
                id="distributors"
                name="distributors"
                class="w-full bg-black/30 border border-white/10 rounded-lg px-4 py-3 text-white focus:border-brand-500 focus:outline-none focus:bg-black/40 transition-colors"
              >
                <option value="1">1 distributeur (test)</option>
                <option value="2-3" selected>2-3 distributeurs</option>
                <option value="4-5">4-5 distributeurs</option>
                <option value="6-10">6-10 distributeurs</option>
                <option value="10+">Plus de 10 distributeurs</option>
                <option value="undecided">Pas encore décidé, à cadrer</option>
              </select>
            </div>

            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="email" class="block text-xs uppercase tracking-[0.1em] text-white/50 mb-2">
                  Email décideur <span class="text-brand-500">*</span>
                </label>
                <input
                  required
                  id="email"
                  name="email"
                  type="email"
                  autocomplete="email"
                  class="w-full bg-black/30 border border-white/10 rounded-lg px-4 py-3 text-white placeholder:text-white/30 focus:border-brand-500 focus:outline-none focus:bg-black/40 transition-colors"
                  placeholder="contact@saint-exemple.fr"
                />
              </div>
              <div>
                <label for="phone" class="block text-xs uppercase tracking-[0.1em] text-white/50 mb-2">
                  Téléphone <span class="text-brand-500">*</span>
                </label>
                <input
                  required
                  id="phone"
                  name="phone"
                  type="tel"
                  autocomplete="tel"
                  class="w-full bg-black/30 border border-white/10 rounded-lg px-4 py-3 text-white placeholder:text-white/30 focus:border-brand-500 focus:outline-none focus:bg-black/40 transition-colors"
                  placeholder="06 12 34 56 78"
                />
              </div>
            </div>

            <div>
              <label for="message" class="block text-xs uppercase tracking-[0.1em] text-white/50 mb-2">
                Message
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                class="w-full bg-black/30 border border-white/10 rounded-lg px-4 py-3 text-white placeholder:text-white/30 focus:border-brand-500 focus:outline-none focus:bg-black/40 transition-colors resize-none"
                placeholder="Décrivez votre site, vos sports cibles, votre timing idéal…"
              ></textarea>
            </div>

            <div class="flex items-start gap-3 pt-2">
              <input
                required
                id="consent"
                type="checkbox"
                class="mt-1 accent-brand-500"
              />
              <label for="consent" class="text-xs text-white/55 font-light leading-relaxed">
                J'accepte que SportLocker me recontacte par email ou téléphone à propos de
                ma demande. Aucune donnée n'est transmise à des tiers
                (<a href="/confidentialite" class="underline hover:text-white">politique de confidentialité</a>).
              </label>
            </div>

            <button type="submit" class="btn btn-primary w-full" id="submit-btn">
              Envoyer ma demande →
            </button>

            <div
              id="form-status"
              class="hidden text-sm rounded-lg p-4 leading-relaxed"
              aria-live="polite"
            >
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  type FormStatus = 'success' | 'error' | 'loading'

  const form = document.getElementById('contact-form') as HTMLFormElement | null
  const status = document.getElementById('form-status') as HTMLDivElement | null
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null

  if (form && status && submitBtn) {
    const setStatus = (kind: FormStatus, text: string) => {
      status.classList.remove('hidden')
      status.classList.remove('bg-brand-500/10', 'border', 'border-brand-500/30', 'text-brand-500')
      status.classList.remove('bg-red-500/10', 'border-red-500/30', 'text-red-300')
      status.classList.remove('bg-white/5', 'border-white/10', 'text-white/70')
      if (kind === 'success') {
        status.classList.add('bg-brand-500/10', 'border', 'border-brand-500/30', 'text-brand-500')
      } else if (kind === 'error') {
        status.classList.add('bg-red-500/10', 'border', 'border-red-500/30', 'text-red-300')
      } else {
        status.classList.add('bg-white/5', 'border', 'border-white/10', 'text-white/70')
      }
      status.textContent = text
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault()
      const data = new FormData(form)
      // Anti-spam honeypot : si rempli, on simule succès silencieux.
      if ((data.get('botcheck') as string)?.length) {
        setStatus('success', 'Demande envoyée. Réponse sous 24h ouvrées.')
        form.reset()
        return
      }
      const key = data.get('access_key') as string
      if (!key) {
        setStatus(
          'error',
          'Le formulaire n\'est pas configuré (clé Web3Forms manquante). Envoyez-nous un email à contact@sportlocker.fr.',
        )
        return
      }
      submitBtn.disabled = true
      submitBtn.textContent = 'Envoi en cours…'
      setStatus('loading', 'Envoi de votre demande…')
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: data,
        })
        const json = (await res.json()) as { success?: boolean; message?: string }
        if (res.ok && json.success) {
          setStatus(
            'success',
            'Demande envoyée. Vous recevrez un email de confirmation et nous revenons vers vous sous 24h ouvrées.',
          )
          form.reset()
        } else {
          throw new Error(json.message ?? 'Erreur inconnue')
        }
      } catch (err) {
        setStatus(
          'error',
          'Impossible d\'envoyer la demande. Envoyez-nous un email à contact@sportlocker.fr.',
        )
      } finally {
        submitBtn.disabled = false
        submitBtn.textContent = 'Envoyer ma demande →'
      }
    })
  }
</script>
