---
import Base from '@/layouts/Base.astro'
import FinalCta from '@/components/FinalCta.astro'
import Faq from '@/components/Faq.astro'
import StickyCta from '@/components/StickyCta.astro'
import PriceCalculator from '@/components/PriceCalculator.tsx'
import { DEPOSITS, MARKETPLACE, PRICING_TEMPLATES, SLOT_DURATIONS } from '@/data/site'

const formatEur = (n: number): string =>
  new Intl.NumberFormat('fr-FR', { maximumFractionDigits: 2 }).format(n) + ' €'

// Illustration concrète du split — basée sur le template Pleine saison
// (un slot 2 h à 5 €) pour rester lisible. Le split 75/25 s'applique
// quelle que soit la durée et le prix configurés par le tenant.
const illustrationCitoyenPrice = 5
const tenantShareExample = illustrationCitoyenPrice * MARKETPLACE.tenantShareRate
const commissionExample = illustrationCitoyenPrice * MARKETPLACE.commissionRate
const tenantShareAvg = MARKETPLACE.citoyenAvgPrice * MARKETPLACE.tenantShareRate

const tenantIncluded = [
  {
    icon: '⚽',
    title: 'Matériel sportif fourni et renouvelé',
    desc: 'Ballons, raquettes, frisbees, équipement plage… Sélection adaptée à votre site. Renouvellement à la mise en service inclus.',
  },
  {
    icon: '🔒',
    title: 'Distributeur antivandal IP54',
    desc: 'Acier inox 2 mm, plage -10°C à +60°C. Garantie matérielle pendant toute la durée de l\'abonnement.',
  },
  {
    icon: '📡',
    title: 'Connectivité 4G M2M incluse',
    desc: 'SIM data illimitée, gestion réseau transparente. Aucune ligne à souscrire de votre côté.',
  },
  {
    icon: '🛠️',
    title: 'Maintenance + hotline N2',
    desc: 'Monitoring 24/7, intervention sur site sous 72h en cas de panne, mises à jour OTA automatiques.',
  },
  {
    icon: '📊',
    title: 'Dashboard temps réel',
    desc: 'Vision live de votre flotte, capture des cautions en cas de dégradation, exports comptables.',
  },
  {
    icon: '💳',
    title: 'Stripe Connect Express activé',
    desc: 'Compte de paiement créé pour vous à la mise en service. Reversement automatique J+2, conformité KYC gérée par Stripe.',
  },
]

const notIncluded = [
  'Travaux de génie civil (ancrage spécifique, dalle béton, arrivée électrique > 5m)',
  'Wrapping personnalisé du distributeur (sticker logo simple inclus)',
  'Remplacement du matériel usé par vétusté normale (à votre charge, financé par votre part des locations)',
  'Frais de transport au-delà de 300 km du site de fabrication (devis sur mesure)',
]

const faqTarifs = [
  {
    q: 'Les citoyens paient à chaque emprunt ?',
    a: 'Oui — à la durée choisie au moment de la réservation : 30 min, 1 h, 1 h 30, 2 h ou la journée (1440 min). Le prix de chaque créneau est défini par vous via le dashboard /pricing. Quatre templates pré-configurés (Communal léger, Pleine saison, Standing 4★ / 5★, Forfait journée seul) permettent de démarrer en quelques clics. Vous pouvez n\'activer que les slots courts, que la journée, ou les deux.',
  },
  {
    q: 'Et la caution ?',
    a: 'La caution est préautorisée sur la CB du citoyen au moment de l\'emprunt (30 à 150 € selon l\'item). Elle n\'est jamais débitée si le matériel revient en bon état. Capturée par vous (tenant) depuis votre dashboard en cas de dégradation ou de non-retour.',
  },
  {
    q: 'Qui gère les remboursements / litiges ?',
    a: 'Vous (tenant) en cas de dégradation : vous capturez la caution ou la libérez depuis le dashboard. SportLocker gère uniquement les bugs techniques (locker pas ouvert, paiement débité par erreur) — remboursement intégral citoyen, dossier résolu sous 24 h.',
  },
  {
    q: 'Si un casier ne s\'ouvre pas après paiement ?',
    a: 'C\'est un cas de bug technique : SportLocker rembourse intégralement le forfait au citoyen et libère la caution. Vous ne portez aucun risque, mais aucun revenu non plus sur ce ticket.',
  },
  {
    q: 'Pourquoi un engagement de 24 / 36 mois ?',
    a: 'Le distributeur coûte 6 à 9 k€ à fabriquer. Pour vous proposer un prix mensuel raisonnable et sans gros CAPEX upfront, on amortit sur la durée.',
  },
  {
    q: 'Le matériel est-il à nous à la fin de l\'engagement ?',
    a: 'Non. SportLocker reste propriétaire du distributeur (pour pouvoir intervenir, remplacer, monitorer). À la fin du contrat : retrait, renouvellement ou option de rachat sur devis.',
  },
  {
    q: 'Y a-t-il une remise pour les déploiements multi-sites ?',
    a: 'Au-delà de 5 distributeurs simultanés, dégressivité tarifaire négociable. À partir de 10, on inclut un module de stats avancées et un account manager dédié.',
  },
  {
    q: 'Comment se passe la facturation de l\'abonnement ?',
    a: 'Facture mensuelle générée le 1er, prélèvement SEPA automatique J+10. Pour les collectivités, virement administratif possible avec mandat émis dans les délais légaux.',
  },
]
---

<Base
  title="Tarifs — marketplace 3-flux : abonnement + locations citoyens"
  description="Tarifs SportLocker : abonnement SaaS à partir de 400 € HT/mois par distributeur + 75 % des locations citoyens reversés via Stripe Connect. Grille tarifaire flexible (30 min à la journée), 4 templates pré-configurés, caution préautorisée 30 à 150 €."
>
  <section class="pt-32 pb-12 sm:pt-40 sm:pb-16 relative overflow-hidden">
    <div class="absolute inset-0 bg-hero-glow" aria-hidden="true"></div>
    <div class="container-x relative">
      <div class="max-w-3xl">
        <span class="tag tag-brand inline-block mb-6" data-reveal>Tarifs</span>
        <h1 class="font-extrabold text-display-xl text-white mb-6" data-reveal data-reveal-delay="1">
          Un modèle marketplace<br/>
          <span class="text-brand-400">3 flux, transparent.</span>
        </h1>
        <p class="text-[1.15rem] text-white/65 leading-loose font-light" data-reveal data-reveal-delay="2">
          L'usager paie à la durée — vous fixez votre propre grille (30 min,
          1 h, 1 h 30, 2 h ou la journée). SportLocker prend 25 % de commission,
          vous gardez 75 % et payez l'abonnement SaaS qui finance le matériel,
          la maintenance et la plateforme. Aucun coût caché.
        </p>
      </div>
    </div>
  </section>

  <!-- SECTION A — LE CITOYEN -->
  <section class="section bg-navy-800">
    <div class="container-x">
      <div class="grid lg:grid-cols-[1fr_1.2fr] gap-12 items-start">
        <div>
          <span class="eyebrow" data-reveal>Section A — Le citoyen</span>
          <h2 class="section-title mt-3 mb-5" data-reveal data-reveal-delay="1">
            5 durées au choix.<br/>Le tenant fixe les prix.
          </h2>
          <p class="section-sub mb-6" data-reveal data-reveal-delay="2">
            Slots de 30, 60, 90 ou 120 minutes, plus la journée entière.
            Le citoyen choisit sa durée dans l'app, réserve un créneau (jusqu'à J+7),
            scanne son QR au distributeur. Restitution dans n'importe quel casier
            libre du réseau, au plus tard à la fin du slot réservé.
          </p>
          <p class="text-sm text-white/55 font-light leading-relaxed" data-reveal data-reveal-delay="3">
            <strong class="text-white/75 font-medium">Caution préautorisée</strong> sur la CB
            du citoyen au moment de l'emprunt (30 à 150 € selon le matériel). Elle n'est
            <em>jamais</em> débitée si le matériel revient en bon état — c'est juste un hold
            Stripe, comme une caution de location de voiture.
          </p>
        </div>

        <div class="card-dark p-7 sm:p-9" data-reveal data-reveal-delay="1">
          <div class="text-xs uppercase tracking-[0.12em] text-white/60 mb-4">
            Caution préautorisée par catégorie
          </div>
          <div class="space-y-3">
            {DEPOSITS.map((d) => (
              <div class="flex justify-between gap-4 items-start py-3 border-b border-white/5 last:border-b-0">
                <div class="flex-1 min-w-0">
                  <div class="text-sm text-white font-medium">{d.category}</div>
                  {d.note && (
                    <div class="text-[0.7rem] text-white/60 font-light leading-relaxed mt-1">{d.note}</div>
                  )}
                </div>
                <div class="font-extrabold text-xl text-brand-400 tabular-nums shrink-0">
                  {d.amount} €
                </div>
              </div>
            ))}
          </div>
          <p class="text-[0.7rem] text-white/60 italic leading-relaxed mt-5">
            La caution est capturée par le tenant en cas de dégradation. Au-delà
            de 150 €, un mandat SEPA in-app couvre la différence.
          </p>
        </div>
      </div>

      <!-- Templates tarifaires -->
      <div class="mt-14">
        <div class="text-center mb-10">
          <span class="eyebrow" data-reveal>4 templates pour démarrer</span>
          <h3 class="font-extrabold text-display-md text-white mt-3" data-reveal data-reveal-delay="1">
            Choisissez votre grille,<br/>ou partez d'un template.
          </h3>
          <p class="section-sub mt-4 mx-auto text-center" data-reveal data-reveal-delay="2">
            Quatre grilles tarifaires pré-configurées, livrées avec le dashboard /pricing.
            Vous pouvez les utiliser telles quelles ou les ajuster créneau par créneau.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {PRICING_TEMPLATES.map((tpl, i) => (
            <div class="card-dark p-6 flex flex-col" data-reveal data-reveal-delay={String((i % 4) + 1)}>
              <div class="text-xs uppercase tracking-[0.12em] text-brand-400 mb-2">
                {tpl.targetSegment === 'mairie'  ? 'Mairie'
                : tpl.targetSegment === 'camping' ? 'Camping & plage'
                : tpl.targetSegment === 'hotel'   ? 'Hôtel'
                : 'Tout type de site'}
              </div>
              <h4 class="font-extrabold text-white text-base mb-2">{tpl.label}</h4>
              <p class="text-xs text-white/55 font-light leading-relaxed mb-4">{tpl.desc}</p>
              <dl class="text-xs space-y-1.5 mt-auto">
                {SLOT_DURATIONS.map((slot) => {
                  const price = tpl.prices[slot.minutes as keyof typeof tpl.prices]
                  return (
                    <div class="flex justify-between gap-2 border-b border-white/5 last:border-b-0 py-1">
                      <dt class="text-white/60">{slot.label}</dt>
                      <dd class={`tabular-nums font-medium ${price ? 'text-white' : 'text-white/25'}`}>
                        {price ? `${formatEur(price)}` : '—'}
                      </dd>
                    </div>
                  )
                })}
              </dl>
            </div>
          ))}
        </div>

        <p class="text-[0.7rem] text-white/60 italic leading-relaxed mt-6 text-center max-w-2xl mx-auto">
          Prix éditables à tout moment depuis votre dashboard. Encaissement Stripe activé — carte, Apple Pay, Google Pay, PayPal et Klarna acceptés.
        </p>
      </div>
    </div>
  </section>

  <!-- SECTION B — LE TENANT -->
  <section class="section bg-navy-900">
    <div class="container-x">
      <div class="text-center mb-10">
        <span class="eyebrow" data-reveal>Section B — Le tenant</span>
        <h2 class="section-title mt-3" data-reveal data-reveal-delay="1">
          Ce que vous payez,<br/>ce que vous touchez.
        </h2>
      </div>

      <div id="simulateur" class="scroll-mt-28" data-reveal data-reveal-delay="2">
        <PriceCalculator client:only="react" />
      </div>

      <div class="mt-10 max-w-3xl mx-auto card-dark p-7 sm:p-9 bg-brand-500/[0.04] border-brand-500/30" data-reveal>
        <div class="flex items-start gap-5">
          <div class="text-4xl shrink-0">💸</div>
          <div>
            <h3 class="font-extrabold text-white text-lg mb-2">Vous gardez 75 % des locations</h3>
            <p class="text-sm text-white/65 font-light leading-relaxed mb-3">
              Sur chaque transaction, 75 % vous reviennent et 25 % vont à SportLocker.
              Reversement automatique J+2 sur votre compte bancaire via Stripe Connect Express.
              Aucune comptabilité manuelle, aucun chèque à éditer.
            </p>
            <p class="text-xs text-white/60 font-light leading-relaxed">
              À titre indicatif : un distributeur mature voit ~ 10 locations/jour. Avec
              un panier moyen de {formatEur(MARKETPLACE.citoyenAvgPrice)}, ça vous fait
              ~ {formatEur(tenantShareAvg * 10 * 30)}/mois de revenu locations net — la
              fourchette varie selon votre grille tarifaire (du template Communal léger
              au Standing 4★ / 5★).
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SECTION C — LA COMMISSION -->
  <section class="section bg-navy-800">
    <div class="container-x">
      <div class="text-center mb-12">
        <span class="eyebrow" data-reveal>Section C — La commission</span>
        <h2 class="section-title mt-3" data-reveal data-reveal-delay="1">
          Comment marche le split<br/>à chaque transaction
        </h2>
      </div>

      <div class="max-w-4xl mx-auto card-dark p-7 sm:p-10 mb-10" data-reveal data-reveal-delay="2">
        <div class="grid sm:grid-cols-[1fr_auto_1fr] gap-6 sm:gap-8 items-center">
          <div class="text-center">
            <div class="text-4xl mb-3">🧑</div>
            <div class="text-xs uppercase tracking-[0.1em] text-white/60 mb-1">Citoyen paie (exemple)</div>
            <div class="font-extrabold text-3xl text-white tabular-nums">{formatEur(illustrationCitoyenPrice)}</div>
            <div class="text-[0.7rem] text-white/60 mt-1">1 slot, prix défini par le tenant</div>
          </div>

          <div class="text-center text-white/60 text-3xl rotate-90 sm:rotate-0 select-none">→</div>

          <div class="text-center">
            <div class="text-4xl mb-3">💳</div>
            <div class="text-xs uppercase tracking-[0.1em] text-white/60 mb-1">Stripe Connect split</div>
            <div class="font-extrabold text-lg text-white">automatique</div>
            <div class="text-[0.7rem] text-white/60 mt-1">à la transaction</div>
          </div>
        </div>

        <div class="mt-8 pt-8 border-t border-white/10 grid sm:grid-cols-2 gap-5">
          <div class="bg-brand-500/[0.08] border border-brand-500/30 rounded-lg p-5">
            <div class="text-xs uppercase tracking-[0.1em] text-brand-400 mb-1.5">Pour vous (tenant)</div>
            <div class="font-extrabold text-3xl text-white tabular-nums">{formatEur(tenantShareExample)}</div>
            <div class="text-xs text-white/60 mt-1.5 font-light">soit 75 % — versé J+2</div>
          </div>
          <div class="bg-white/5 border border-white/10 rounded-lg p-5">
            <div class="text-xs uppercase tracking-[0.1em] text-white/60 mb-1.5">Pour SportLocker</div>
            <div class="font-extrabold text-3xl text-white tabular-nums">{formatEur(commissionExample)}</div>
            <div class="text-xs text-white/60 mt-1.5 font-light">soit 25 % de commission</div>
          </div>
        </div>

        <p class="text-[0.7rem] text-white/60 italic leading-relaxed mt-6">
          Exemple basé sur un slot à 5 € (typique des templates Pleine saison ou
          Forfait journée seul). Le ratio 75 / 25 s'applique à toute durée et à tout
          prix configurés dans votre grille — d'un slot 30 min à 0,50 € à un slot
          journée à 15 €.
        </p>
      </div>

      <div class="max-w-3xl mx-auto card-dark p-7 sm:p-9" data-reveal>
        <h3 class="font-extrabold text-white text-base mb-4">Pourquoi 25 % de commission ?</h3>
        <ul class="space-y-3 text-sm text-white/65 font-light">
          <li class="flex gap-3">
            <span class="text-brand-400 shrink-0">·</span>
            <span><strong class="text-white/85 font-medium">Standard marketplaces B2C</strong> — Uber Eats prend 30 %, Deliveroo 30 %, Airbnb 15 %. SportLocker se situe dans la fourchette basse.</span>
          </li>
          <li class="flex gap-3">
            <span class="text-brand-400 shrink-0">·</span>
            <span><strong class="text-white/85 font-medium">Frais Stripe Connect</strong> — 1,4 % + 0,25 € absorbés par SportLocker sur sa commission, pas répercutés sur vous.</span>
          </li>
          <li class="flex gap-3">
            <span class="text-brand-400 shrink-0">·</span>
            <span><strong class="text-white/85 font-medium">Maintenance + support N2</strong> — la commission finance la hotline 7j/7, le monitoring 24/24 et les mises à jour OTA.</span>
          </li>
          <li class="flex gap-3">
            <span class="text-brand-400 shrink-0">·</span>
            <span><strong class="text-white/85 font-medium">Compense l'abo bas</strong> — sans commission, l'abonnement mensuel serait 2× plus cher pour couvrir le même coût opérationnel.</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- INCLUS -->
  <section class="section bg-navy-900">
    <div class="container-x">
      <div class="text-center mb-14">
        <span class="eyebrow" data-reveal>Ce que l'abonnement couvre</span>
        <h2 class="section-title mt-3" data-reveal data-reveal-delay="1">
          Tout est inclus.<br/>Vraiment tout.
        </h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-14">
        {tenantIncluded.map((it, i) => (
          <div class="card-dark p-7" data-reveal data-reveal-delay={String((i % 3) + 1)}>
            <div class="w-12 h-12 rounded-lg bg-brand-500/10 border border-brand-500/30 grid place-items-center text-2xl mb-5">
              {it.icon}
            </div>
            <h3 class="font-bold text-white text-base mb-2.5">{it.title}</h3>
            <p class="text-sm text-white/55 font-light leading-relaxed">{it.desc}</p>
          </div>
        ))}
      </div>

      <div class="card-dark p-7 sm:p-9 max-w-3xl mx-auto" data-reveal>
        <div class="text-xs uppercase tracking-[0.12em] text-white/60 mb-4">
          Ce qui n'est PAS inclus
        </div>
        <ul class="space-y-3">
          {notIncluded.map((item) => (
            <li class="flex items-start gap-3 text-sm text-white/65 font-light">
              <span class="text-white/60 mt-0.5 shrink-0">·</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-navy-800">
    <div class="container-x">
      <div class="text-center mb-12">
        <span class="eyebrow" data-reveal>Questions fréquentes</span>
        <h2 class="section-title mt-3" data-reveal data-reveal-delay="1">
          Tout ce qu'on nous demande<br/>sur le modèle marketplace
        </h2>
      </div>
      <Faq items={faqTarifs} />
    </div>
  </section>

  <FinalCta
    title="Un devis chiffré sous 48h."
    sub="Donnez-nous votre configuration cible (type de site, nb distributeurs, options) et on revient avec un devis ferme incluant simulation de revenu locations."
    primary={{ href: '/contact#formulaire', label: 'Demander un devis détaillé' }}
    secondary={{ href: '/comment-ca-marche#installation', label: 'Voir le parcours d\'installation' }}
  />

  <StickyCta />
</Base>
