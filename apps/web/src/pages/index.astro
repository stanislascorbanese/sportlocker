---
import Base from '@/layouts/Base.astro'
import Hero from '@/components/Hero.astro'
import ContactForm from '@/components/ContactForm.astro'
import Faq from '@/components/Faq.astro'
import MiniSimulator from '@/components/MiniSimulator.tsx'
import LockerDistributor3D from '@/components/LockerDistributor3D.astro'
import { PRICING_TEMPLATES, SITE, SLOT_DURATIONS } from '@/data/site'

const formatEur = (n: number): string =>
  new Intl.NumberFormat('fr-FR', { maximumFractionDigits: 2 }).format(n) + ' €'

const problems = [
  {
    n: '34%',
    label: 'des pratiquants renoncent à une session par manque de matériel',
  },
  { n: '8%', label: 'des sites proposent un prêt de matos au guichet' },
  { n: '0€', label: 'de budget exploitation après la construction du terrain' },
  { n: '24/7', label: 'à couvrir — impossible avec un agent à plein temps' },
]

const pillars = [
  {
    icon: '🔓',
    title: 'Libre-service 24/7',
    desc: 'Vos usagers empruntent en 30 secondes, à toute heure, sans gardien ni accueil dédié.',
  },
  {
    icon: '🛠️',
    title: 'Zéro personnel à mobiliser',
    desc: 'Maintenance proactive (alertes télémétriques temps réel), hotline, mises à jour OTA : tout est inclus dans l\'abonnement. Vous ne gérez rien.',
  },
  {
    icon: '💸',
    title: 'Revenu locations partagé',
    desc: 'Vous fixez la grille — 5 créneaux (30 min, 1 h, 1 h 30, 2 h ou la journée). Vous gardez 75 % de chaque location, SportLocker prend 25 % de commission.',
  },
]

const useCases = [
  {
    href: '/mairies',
    icon: '🏟️',
    tag: 'Stades municipaux',
    title: 'Parcs et city stades',
    desc: 'Ballons foot/basket, raquettes et frisbees pour les familles, les clubs amateurs et le sport scolaire hors temps école.',
    cta: 'Solution mairies',
  },
  {
    href: '/campings',
    icon: '🏖️',
    tag: 'Plages publiques & campings',
    title: 'Bord de mer & sites côtiers',
    desc: 'Raquettes de plage, balles, équipement snorkel, ping-pong outdoor. Service actif 24/7 pour vos campeurs et la fréquentation locale.',
    cta: 'Solution campings & plages',
  },
  {
    href: '/hotels',
    icon: '✨',
    tag: 'Complexes hôteliers',
    title: 'Hôtels 3★ / 4★ / 5★',
    desc: 'Matériel premium (raquettes Wilson, équipement pool de marque) pour différencier l\'expérience client et booster les avis Booking.',
    cta: 'Solution hôtels',
  },
]

const citoyenSteps = [
  { n: '01', title: 'Je trouve un casier', desc: 'L\'app affiche les distributeurs proches avec le stock en temps réel.' },
  { n: '02', title: 'Je choisis ma durée', desc: '5 slots possibles (30 min, 1 h, 1 h 30, 2 h ou la journée) — l\'opérateur du site active ceux qu\'il propose. Caution préautorisée sur la CB (libérée si retour OK).' },
  { n: '03', title: 'J\'ouvre avec mon QR', desc: 'Scan devant le casier, ouverture en moins d\'une seconde. Fonctionne sans réseau.' },
  { n: '04', title: 'Je joue puis je rends', desc: 'À la fin de mon créneau, je remets le matériel dans le casier et je le referme. Caution libérée automatiquement.' },
]

const clientSteps = [
  { n: '01', title: 'Devis & cadrage', desc: 'Visite ou call de 15 min, étude du site, devis sous 48 h.' },
  { n: '02', title: 'Visite technique', desc: 'Repérage des emplacements, alimentation électrique, signalétique.' },
  { n: '03', title: 'Installation', desc: 'Pose, configuration, formation du responsable de site. Clé en main.' },
  { n: '04', title: 'Lancement & suivi', desc: 'Communication usagers, suivi 30/60/90 jours, reversement automatique J+2 via Stripe Connect.' },
]

const competitors = [
  {
    name: 'Decathlon Rent',
    model: 'Location en magasin, horaires limités',
    diff: 'SportLocker = 24/7, sans personnel, sur vos terrains.',
  },
  {
    name: 'Equip (paddle libre-service)',
    model: 'Niche paddle, marché local',
    diff: 'SportLocker = catalogue multi-sport, déploiement national.',
  },
  {
    name: 'Locations municipales classiques',
    model: 'Manuel, accueil aux horaires d\'ouverture',
    diff: 'SportLocker = automatisé, scalable, revenu partagé.',
  },
]

const faq = [
  {
    q: 'Combien ça coûte pour mon site ?',
    a: 'Abonnement à partir de 400 € HT / mois / distributeur, tout inclus (matériel, maintenance, support, mises à jour). En parallèle, vos usagers paient à la location selon la grille que vous fixez (slots de 30 min à la journée) et vous gardez 75 % de chaque transaction. Voir la page tarifs pour la simulation détaillée.',
  },
  {
    q: 'Qui paie le matériel sportif (ballons, raquettes, etc.) ?',
    a: 'Le matériel initial et son renouvellement sont compris dans l\'abonnement SaaS. Vous restez en charge du remplacement matériel usé par vétusté normale, ce qui est financé par votre part des locations.',
  },
  {
    q: 'Et si un usager casse ou ne rend pas le matériel ?',
    a: 'L\'usager pose une caution Stripe préautorisée au moment de l\'emprunt (30 à 150 € selon l\'item). En cas de dégradation ou de non-retour, vous capturez la caution depuis votre dashboard. Pour un risque > 150 € il existe un mandat SEPA in-app sur le citoyen.',
  },
  {
    q: 'Le service est-il payant pour mes usagers ?',
    a: 'Oui — modèle marketplace. L\'inscription à l\'app et la consultation des distributeurs sont gratuites. Chaque location est facturée selon votre grille (30 min, 1 h, 1 h 30, 2 h ou journée — vous choisissez les durées et les prix). Quatre templates pré-configurés sont fournis pour démarrer (Communal léger, Pleine saison, Standing 4★ / 5★, Forfait journée seul). Sur chaque transaction, vous récupérez 75 % et SportLocker prend 25 % de commission.',
  },
  {
    q: 'Comment je récupère ma part des locations ?',
    a: 'Reversement automatique en J+2 sur votre compte bancaire via Stripe Connect Express. Suivi en temps réel depuis votre dashboard SportLocker.',
  },
  {
    q: 'Quel est le délai de mise en service ?',
    a: 'De la signature à la mise en service : 4 à 6 semaines en moyenne. Cela inclut la fabrication, l\'installation et la formation.',
  },
  {
    q: 'Comment je sais si un distributeur tombe en panne ?',
    a: 'Votre dashboard a une vue « Santé du parc » qui agrège en temps réel l\'état de tous vos distributeurs : connectivité, température CPU, signal 4G, mémoire libre, batterie. Des alertes seuils (offline, silence > 24 h, surchauffe, signal faible, tickets critiques) remontent en haut de liste les sites qui demandent de l\'attention. Notre support intervient à distance sur 80 % des incidents avant que vous n\'ayez à le signaler.',
  },
]

// JSON-LD additionnels pour la home — exposent l'offre Service à Google et
// la FAQ dans les rich results (cards avec questions extensibles dans les
// SERPs). Ces schemas sont surchargés par-dessus l'`Organization` global
// de Base.astro.
const serviceJsonLd = {
  '@type': 'Service',
  name: 'Distributeurs de matériel sportif en libre-service',
  serviceType: 'SaaS · IoT · marketplace location matériel sportif',
  description:
    'Solution clé en main pour mairies, campings et hôtels : distributeurs IoT 24/7 + dashboard ops + app citoyen avec créneaux 30 min à journée. Vous gardez 75 % de chaque location.',
  provider: {
    '@type': 'Organization',
    name: 'SportLocker SAS',
    url: 'https://sportlocker.fr',
  },
  areaServed: { '@type': 'Country', name: 'France' },
  audience: { '@type': 'BusinessAudience', name: 'Mairies, campings, hôtels' },
  offers: {
    '@type': 'AggregateOffer',
    priceCurrency: 'EUR',
    lowPrice: 400,
    highPrice: 475,
    offerCount: 3,
    description: 'Abonnement SaaS mensuel par distributeur, tout inclus.',
  },
}

const faqJsonLd = {
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
}
---

<Base
  title="Distributeurs de matériel sportif en libre-service 24/7"
  description="SportLocker installe des distributeurs IoT de matériel sportif sur vos sites. Marketplace 3-flux : abonnement SaaS, locations citoyens à la durée (30 min à la journée, prix paramétrable), vous gardez 75 %. Solution clé en main pour mairies, campings et hôtels."
  extraJsonLd={[serviceJsonLd, faqJsonLd]}
>
  <Hero
    tag="Premier réseau marketplace en France · 2026"
    title="Le sport en libre-service,"
    highlight="24/7, sur vos sites."
    desc="SportLocker installe des distributeurs connectés sur vos terrains publics, plages, campings et hôtels. Vos usagers empruntent ballon, raquette ou matos plage en 30 secondes — durée au choix (30 min à la journée), prix que vous fixez. Vous gardez 75 % du chiffre, SportLocker prend l'opérationnel."
    primary={{ href: '/contact#formulaire', label: 'Demander un devis' }}
    secondary={{ href: '/comment-ca-marche#distributeur-3d', label: 'Voir comment ça marche' }}
  >
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 mt-16 pt-10 border-t border-white/10 max-w-2xl" data-reveal data-reveal-delay="4">
      <div>
        <div class="font-extrabold text-3xl text-white">5</div>
        <div class="text-xs text-white/60 mt-1">Durées au choix<br/>30 min → journée</div>
      </div>
      <div>
        <div class="font-extrabold text-3xl text-white">75<span class="text-brand-500">%</span></div>
        <div class="text-xs text-white/60 mt-1">Reversement<br/>au tenant (J+2)</div>
      </div>
      <div>
        <div class="font-extrabold text-3xl text-white">0</div>
        <div class="text-xs text-white/60 mt-1">Concurrent direct<br/>identifié en France</div>
      </div>
      <div>
        <div class="font-extrabold text-3xl text-white">30<span class="text-brand-500">s</span></div>
        <div class="text-xs text-white/60 mt-1">Pour emprunter<br/>du matériel</div>
      </div>
    </div>
  </Hero>

  <!-- PROBLÈME -->
  <section class="section bg-navy-800">
    <div class="container-x">
      <div class="grid lg:grid-cols-2 gap-14 items-center">
        <div>
          <span class="eyebrow" data-reveal>Le constat</span>
          <h2 class="section-title mt-3 mb-5" data-reveal data-reveal-delay="1">
            Vos terrains sont là.<br/>Le matériel n'y est pas.
          </h2>
          <p class="section-sub" data-reveal data-reveal-delay="2">
            Stades publics, plages, campings, hôtels — tous ces sites ont des terrains, des courts,
            des piscines. Mais sans matériel disponible, ils restent sous-utilisés. Et personne
            n'a le budget pour mettre un agent dédié 7j/7.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-3" data-reveal data-reveal-delay="3">
          {problems.map((p) => (
            <div class="card-dark p-5">
              <div class="font-extrabold text-3xl text-brand-500">{p.n}</div>
              <div class="text-xs text-white/60 mt-1.5 font-light leading-relaxed">{p.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- SOLUTION 3 PILIERS -->
  <section class="section bg-navy-900">
    <div class="container-x">
      <div class="text-center mb-14">
        <span class="eyebrow" data-reveal>Notre réponse</span>
        <h2 class="section-title mt-3 mx-auto" data-reveal data-reveal-delay="1">
          Une infrastructure marketplace<br/>prête à l'emploi
        </h2>
        <p class="section-sub mt-4 mx-auto text-center" data-reveal data-reveal-delay="2">
          Trois piliers pour transformer vos sites en services sportifs autonomes et rentables.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-5">
        {pillars.map((p, i) => (
          <div class="card-dark p-8 hover:border-brand-500/30 transition-colors" data-reveal data-reveal-delay={String(i + 1)}>
            <div class="w-12 h-12 rounded-lg bg-brand-500/10 border border-brand-500/30 grid place-items-center text-2xl mb-5">
              {p.icon}
            </div>
            <h3 class="font-extrabold text-lg text-white mb-3">{p.title}</h3>
            <p class="text-sm text-white/55 leading-relaxed font-light">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3 USE CASES PREMIUM -->
  <section class="section bg-navy-800">
    <div class="container-x">
      <div class="text-center mb-14">
        <span class="eyebrow" data-reveal>Pour qui</span>
        <h2 class="section-title mt-3" data-reveal data-reveal-delay="1">
          Trois segments,<br/>trois configurations dédiées.
        </h2>
        <p class="section-sub mt-4 mx-auto text-center" data-reveal data-reveal-delay="2">
          Chaque type de site a sa landing avec arguments métier, cas d'usage et simulation budget.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-5">
        {useCases.map((s, i) => (
          <a
            href={s.href}
            class="card-dark p-8 sm:p-10 hover:border-brand-500/40 hover:bg-white/[0.06] transition-all group"
            data-reveal
            data-reveal-delay={String(i + 1)}
          >
            <div class="text-4xl mb-5">{s.icon}</div>
            <div class="text-[0.65rem] uppercase tracking-[0.14em] text-brand-500/80 mb-2">{s.tag}</div>
            <h3 class="font-extrabold text-xl text-white mb-3">{s.title}</h3>
            <p class="text-sm text-white/60 mb-6 font-light leading-relaxed">{s.desc}</p>
            <span class="inline-flex items-center gap-2 text-brand-500 font-medium text-sm group-hover:gap-3 transition-all">
              {s.cta} <span>→</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- COMMENT ÇA MARCHE TEASER -->
  <section id="comment-ca-marche" class="section bg-navy-900">
    <div class="container-x">
      <div class="text-center mb-14">
        <span class="eyebrow" data-reveal>Comment ça marche</span>
        <h2 class="section-title mt-3" data-reveal data-reveal-delay="1">
          De zéro à la pratique<br/>en 30 secondes.
        </h2>
      </div>

      <div class="grid lg:grid-cols-2 gap-10">
        <div data-reveal>
          <div class="text-xs uppercase tracking-[0.14em] text-white/60 mb-5">Côté usager</div>
          <ol class="space-y-4">
            {citoyenSteps.map((s) => (
              <li class="card-dark p-5 flex gap-4">
                <div class="font-extrabold text-2xl text-brand-500/40 leading-none w-10 shrink-0">{s.n}</div>
                <div>
                  <div class="font-bold text-white mb-1">{s.title}</div>
                  <div class="text-sm text-white/60 font-light">{s.desc}</div>
                </div>
              </li>
            ))}
          </ol>
        </div>

        <div data-reveal data-reveal-delay="1">
          <div class="text-xs uppercase tracking-[0.14em] text-white/60 mb-5">Côté établissement</div>
          <ol class="space-y-4">
            {clientSteps.map((s) => (
              <li class="card-dark p-5 flex gap-4">
                <div class="font-extrabold text-2xl text-brand-500/40 leading-none w-10 shrink-0">{s.n}</div>
                <div>
                  <div class="font-bold text-white mb-1">{s.title}</div>
                  <div class="text-sm text-white/60 font-light">{s.desc}</div>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>

      <div class="text-center mt-12">
        <a href="/comment-ca-marche#distributeur-3d" class="btn btn-outline">Voir le détail complet →</a>
      </div>
    </div>
  </section>

  <!-- DISTRIBUTEUR 3D -->
  <section class="section bg-navy-900 border-t border-white/[0.04]">
    <div class="container-x">
      <div class="text-center mb-10 max-w-3xl mx-auto">
        <span class="eyebrow" data-reveal>Le distributeur en 3D</span>
        <h2 class="section-title mt-3" data-reveal data-reveal-delay="1">
          Voilà à quoi ressemble<br/><span class="text-brand-500">la borne installée chez vous.</span>
        </h2>
        <p class="section-sub mt-4 mx-auto text-center" data-reveal data-reveal-delay="2">
          Faites-la pivoter, ouvrez les portes, survolez les étiquettes pour découvrir chaque composant.
          Borne réelle, 8 casiers mixtes, alimentée par panneau solaire.
        </p>
      </div>

      <div class="max-w-5xl mx-auto" data-reveal data-reveal-delay="3">
        <LockerDistributor3D />
      </div>
    </div>
  </section>

  <!-- MODÈLE TARIFAIRE — section visuelle compacte des 5 durées + 4 templates.
       Donne une intuition immédiate du modèle slots avant que le visiteur n'aille
       sur /tarifs pour le détail complet. -->
  <section class="section bg-navy-900 border-t border-white/[0.04]">
    <div class="container-x">
      <div class="text-center mb-12 max-w-2xl mx-auto">
        <span class="eyebrow" data-reveal>Modèle tarifaire en un coup d'œil</span>
        <h2 class="section-title mt-3 mb-4" data-reveal data-reveal-delay="1">
          Cinq durées au choix.<br/><span class="text-brand-500">Vous fixez les prix.</span>
        </h2>
        <p class="section-sub mx-auto text-center" data-reveal data-reveal-delay="2">
          Pas de forfait journée imposé, pas de tarif unique national. Chaque tenant configure
          sa grille (slots de 30 min à la journée) et active seulement les durées qui ont du
          sens pour son site. Quatre templates livrés pour démarrer en 2 clics.
        </p>
      </div>

      <!-- 5 durées disponibles -->
      <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 max-w-4xl mx-auto mb-10" data-reveal data-reveal-delay="3">
        {SLOT_DURATIONS.map((slot) => (
          <div class="card-dark p-4 text-center">
            <div class="font-extrabold text-white text-lg">{slot.label}</div>
            <div class="text-[0.65rem] uppercase tracking-wider text-brand-500/70 mt-1.5">
              {slot.minutes === 1440 ? 'Forfait jour' : `${slot.minutes} min`}
            </div>
          </div>
        ))}
      </div>

      <!-- 4 templates pré-configurés -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 max-w-5xl mx-auto" data-reveal data-reveal-delay="4">
        {PRICING_TEMPLATES.map((tpl) => (
          <div class="card-dark p-5 flex flex-col">
            <div class="text-xs uppercase tracking-[0.1em] text-brand-500/80 mb-2">
              {tpl.targetSegment === 'mairie'  ? 'Mairie'
              : tpl.targetSegment === 'camping' ? 'Camping'
              : tpl.targetSegment === 'hotel'   ? 'Hôtel'
              : 'Tout type de site'}
            </div>
            <h3 class="font-bold text-white text-base mb-3">{tpl.label}</h3>
            <dl class="text-xs space-y-1 mt-auto">
              {SLOT_DURATIONS.map((slot) => {
                const price = tpl.prices[slot.minutes as keyof typeof tpl.prices]
                return (
                  <div class="flex justify-between gap-2">
                    <dt class="text-white/60">{slot.label}</dt>
                    <dd class={`tabular-nums font-medium ${price ? 'text-white/85' : 'text-white/20'}`}>
                      {price ? formatEur(price) : '—'}
                    </dd>
                  </div>
                )
              })}
            </dl>
          </div>
        ))}
      </div>

      <p class="mt-8 text-center text-xs text-white/60 font-light" data-reveal data-reveal-delay="5">
        Reversement automatique J+2 sur votre compte bancaire via Stripe Connect.
        <a href="/tarifs#simulateur" class="text-brand-500 hover:underline">Détail du split 75/25 et simulation budgétée →</a>
      </p>
    </div>
  </section>

  <!-- SIMULATEUR TEASER -->
  <section class="section bg-navy-800">
    <div class="container-x">
      <div class="text-center mb-10 max-w-2xl mx-auto">
        <span class="eyebrow" data-reveal>Estimez en 30 secondes</span>
        <h2 class="section-title mt-3 mb-4" data-reveal data-reveal-delay="1">
          Combien ça coûte<br/><span class="text-brand-500">pour votre site ?</span>
        </h2>
        <p class="section-sub mx-auto text-center" data-reveal data-reveal-delay="2">
          Choisissez votre type d'établissement et sa taille — on calcule le budget année 1
          (subventions ANS/DETR estimées pour les mairies) et l'excédent attendu en croisière.
        </p>
      </div>

      <div class="max-w-5xl mx-auto" data-reveal data-reveal-delay="3">
        <MiniSimulator client:load />
      </div>
    </div>
  </section>

  <!-- CONCURRENCE -->
  <section class="section bg-navy-900">
    <div class="container-x">
      <div class="text-center mb-14">
        <span class="eyebrow" data-reveal>Différenciation</span>
        <h2 class="section-title mt-3" data-reveal data-reveal-delay="1">
          Aucun équivalent<br/>multi-sport 24/7 en France.
        </h2>
      </div>
      <div class="grid md:grid-cols-3 gap-5">
        {competitors.map((c, i) => (
          <div class="card-dark p-7" data-reveal data-reveal-delay={String(i + 1)}>
            <div class="font-extrabold text-white mb-2">{c.name}</div>
            <div class="text-xs text-white/60 uppercase tracking-wider mb-4">{c.model}</div>
            <div class="text-sm text-brand-500 font-light leading-relaxed">{c.diff}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section bg-navy-800">
    <div class="container-x">
      <div class="text-center mb-12">
        <span class="eyebrow" data-reveal>Questions fréquentes</span>
        <h2 class="section-title mt-3" data-reveal data-reveal-delay="1">
          Les questions qu'on nous pose le plus
        </h2>
      </div>
      <Faq items={faq} />
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact" class="section bg-navy-900 relative overflow-hidden">
    <div class="absolute inset-0 bg-hero-glow" aria-hidden="true"></div>
    <div class="container-x relative">
      <div class="grid lg:grid-cols-[1fr_1.4fr] gap-12 lg:gap-16 items-start">
        <div class="lg:sticky lg:top-32">
          <span class="tag tag-brand inline-block mb-6" data-reveal>Demander un devis</span>
          <h2 class="font-extrabold text-display-lg text-white mb-5" data-reveal data-reveal-delay="1">
            Vos terrains méritent<br/>
            <span class="text-brand-500">du matériel.</span>
          </h2>
          <p class="text-white/65 leading-relaxed font-light mb-9" data-reveal data-reveal-delay="2">
            15 minutes pour voir si SportLocker a du sens pour votre site.
            Aucun engagement au-delà de la conversation. Réponse sous 24h ouvrées.
          </p>

          <div class="space-y-5 text-sm" data-reveal data-reveal-delay="3">
