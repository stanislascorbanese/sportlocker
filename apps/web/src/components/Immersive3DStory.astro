---
// Scrollytelling 3D : une seule scène WebGL (Three.js r128, lazy CDN) dont la
// caméra voyage au fil du scroll en 3 actes — App → Scan → Casier-composants.
// Réutilise les helpers de construction du casier (rcol/rtex/rframe/tex…) et la
// technique de chargement lazy + IntersectionObserver de LockerDistributor3D.
//
// Perf : init seulement à l'entrée dans le viewport, rAF mis en pause hors-vue,
// dispose() au démontage. On ne rend que quand la caméra/les portes bougent.
// A11y : prefers-reduced-motion → pas de scène scroll-driven, fallback HTML
// statique pleinement lisible. Le contenu informatif existe en texte HTML.

const acts = [
  {
    k: 'app',
    eyebrow: 'Acte 1 — Sur le téléphone',
    title: "Tout commence dans l'app",
    desc: "Je repère un casier sur la carte, je choisis ma durée, l'app génère mon QR code. Trois écrans, trente secondes.",
  },
  {
    k: 'scan',
    eyebrow: 'Acte 2 — Le scan',
    title: 'Mon téléphone parle à la borne',
    desc: "Je présente le QR au lecteur du distributeur. Le décodage est local (JWT HS256) : ça déverrouille même sans réseau, en moins d'une seconde.",
  },
  {
    k: 'locker',
    eyebrow: 'Acte 3 — La borne',
    title: 'Le casier et ses composants',
    desc: "La porte s'ouvre. La borne se décompose : écran tactile, lecteur QR, clavier PIN, panneau solaire et casiers antivandal.",
  },
]

// Composants annotés — existent aussi en texte pur (fallback + a11y).
const components = [
  { t: 'Écran tactile 7"', d: "Capacitif antivandale. Stock en temps réel, guide l'usager pendant la réservation." },
  { t: 'Lecteur QR code', d: 'Caméra industrielle, décodage offline. Déverrouillage < 1 s même sans réseau.' },
  { t: 'Clavier code PIN', d: 'Pour les usagers sans smartphone. Code unique valable 15 min.' },
  { t: 'Panneau solaire', d: 'Module 80 W + batterie LiFePO4. Autonomie 5 jours sans soleil.' },
  { t: 'Casiers antivandal', d: 'Acier, IP54, verrou électromécanique. Grands (matériel long) et petits (ballons).' },
]

// Cartes d'annotation overlay (style app) affichées quand la caméra cadre un
// composant. `s`/`e` = plage de progression scroll où la carte est visible.
// `icon` = glyphe SVG path-less (emoji-free) dessiné en CSS mask via data-icon.
const annotations = [
  // Acte 1 — l'app
  { icon: 'map', t: 'Carte temps réel', d: 'Les casiers libres autour de moi, stock live servi en moins de 20 ms.', s: 0.0, e: 0.13 },
  { icon: 'clock', t: 'Choix du créneau', d: 'Slots 30 / 60 / 90 / 120 min, prix affiché par la commune.', s: 0.13, e: 0.24 },
  { icon: 'card', t: 'Paiement Stripe', d: 'Carte, Apple Pay, Google Pay, PayPal — réglé en un geste.', s: 0.24, e: 0.33 },
  { icon: 'qr', t: 'QR hors-ligne', d: 'JWT HS256 signé sur le téléphone, valable 15 min même sans réseau.', s: 0.33, e: 0.5 },
  // Acte 3 — la borne (cadrée composant par composant)
  { icon: 'screen', t: 'Écran tactile 7"', d: "Capacitif antivandale, guide l'usager et affiche le stock en temps réel.", s: 0.66, e: 0.74 },
  { icon: 'qr', t: 'Lecteur QR', d: 'Caméra industrielle, décodage offline. Déverrouillage en moins d’une seconde.', s: 0.74, e: 0.81 },
  { icon: 'pin', t: 'Clavier code PIN', d: 'Pour les usagers sans smartphone : code unique valable 15 min.', s: 0.81, e: 0.88 },
  { icon: 'sun', t: 'Panneau solaire', d: 'Module 80 W + batterie LiFePO4, 5 jours d’autonomie sans soleil.', s: 0.88, e: 0.95 },
  { icon: 'lock', t: 'Casiers + LED', d: 'Acier IP54, verrou électromécanique, LED de statut par casier.', s: 0.95, e: 1.01 },
]
---

<div id="i3d-root" class="relative" data-i3d>
  <!-- Zone de scroll haute : la scène est sticky pendant qu'on parcourt ces 300vh -->
  <div id="i3d-scroll" class="relative" style="height:300vh">
    <div id="i3d-sticky" class="sticky top-0 h-screen w-full overflow-hidden">
      <div
        id="i3d-stage"
        class="absolute inset-0"
        role="img"
        aria-label="Animation 3D pilotée au défilement : un téléphone affiche les écrans de l'application SportLocker, un faisceau de scan QR relie le téléphone au distributeur, puis le distributeur s'ouvre et présente ses composants — écran tactile, lecteur QR, clavier PIN, panneau solaire et casiers."
      ></div>

      <!-- Légendes HTML en overlay : animées en transform/opacity uniquement -->
      <div id="i3d-captions" class="pointer-events-none absolute inset-0 z-10" aria-hidden="true">
        <!-- Scrim dégradé navy (lower-third ciné) : garde le texte lisible sur la 3D
             sans masquer le sujet central. Gauche sur desktop, bas sur mobile. -->
        <div class="i3d-scrim" aria-hidden="true"></div>
        <div class="container-x h-full flex items-end sm:items-center pb-16 sm:pb-0 relative">
          <div class="max-w-md">
            {acts.map((a, i) => (
              <div class="i3d-caption" data-caption={String(i)} style="position:absolute;will-change:transform,opacity">
                <span class="tag tag-brand mb-3 inline-block">{a.eyebrow}</span>
                <h3 class="font-extrabold text-display-md text-white mb-3">{a.title}</h3>
                <p class="text-[1rem] leading-relaxed text-white/65 font-light">{a.desc}</p>
              </div>
            ))}
          </div>
        </div>
        <!-- Indice de défilement (acte 1 seulement) -->
        <div id="i3d-hint" class="absolute left-1/2 bottom-6 -translate-x-1/2 text-white/45 text-xs uppercase tracking-[0.14em] flex flex-col items-center gap-1">
          <span>Défilez pour explorer</span>
          <span class="text-base leading-none">↓</span>
        </div>
      </div>

      <!-- Cartes d'annotation par composant (style app, verre navy + blur).
           Une seule visible à la fois ; animées en transform/opacity. -->
      <div id="i3d-annot" class="pointer-events-none absolute inset-0 z-20" aria-hidden="true">
        <div class="container-x h-full flex items-center justify-end">
          <div class="relative w-[19rem] max-w-[80vw] h-44">
            {annotations.map((a, i) => (
              <div class="i3d-annot-card" data-annot={String(i)} data-range={`${a.s},${a.e}`}>
                <div class="flex items-start gap-3">
                  <span class={`i3d-annot-ic i3d-ic-${a.icon}`} aria-hidden="true"></span>
                  <div>
                    <div class="i3d-annot-t">{a.t}</div>
                    <div class="i3d-annot-d">{a.d}</div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- FALLBACK statique : visible si prefers-reduced-motion, pas de WebGL,
       ou si la 3D échoue. Contenu informatif complet en HTML pur. -->
  <div id="i3d-fallback" class="hidden">
    <div class="card-dark p-6 sm:p-8">
      <span class="tag tag-brand mb-4 inline-block">L'expérience, de bout en bout</span>
      <h3 class="font-extrabold text-display-md text-white mb-3">De l'app au casier ouvert</h3>
      <p class="section-sub mb-8">
        Je réserve sur mon téléphone, je présente mon QR au lecteur de la borne, le casier
        s'ouvre. La borne réunit cinq composants clés :
      </p>
      <ul class="grid sm:grid-cols-2 gap-4">
        {components.map((c) => (
          <li class="card-dark p-5">
            <div class="font-bold text-white text-sm mb-1.5">{c.t}</div>
            <div class="text-sm text-white/55 font-light leading-relaxed">{c.d}</div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</div>

<script is:inline define:vars={{ COMPONENTS: components }}>
  (function () {
    var root = document.getElementById('i3d-root');
    var scroll = document.getElementById('i3d-scroll');
    var sticky = document.getElementById('i3d-sticky');
    var stage = document.getElementById('i3d-stage');
    var captionsWrap = document.getElementById('i3d-captions');
    var fallback = document.getElementById('i3d-fallback');
    var hint = document.getElementById('i3d-hint');
    if (!root || !stage) return;

    var reduce =
      window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var hasWebGL = (function () {
      try {
        var c = document.createElement('canvas');
        return !!(window.WebGLRenderingContext && (c.getContext('webgl') || c.getContext('experimental-webgl')));
      } catch (e) {
        return false;
      }
    })();

    function showFallback() {
      if (scroll) scroll.style.display = 'none';
      if (fallback) fallback.classList.remove('hidden');
    }

    // Pas de scène scroll-driven si mouvement réduit ou WebGL absent.
    if (reduce || !hasWebGL) {
      showFallback();
      return;
    }

    var isMobile = window.matchMedia('(max-width: 767px)').matches;
    var loaded = false;
    var disposed = false;
    var THREE;
    var renderer, scene, camera;
    var rafId = null;
    var running = false; // boucle rAF active (section dans le viewport)
    var dirty = true; // un re-render est nécessaire
    var progress = 0; // 0 → 1, position de scroll dans la zone
    var smooth = 0; // progress lissé (lerp) pour des mouvements fluides
    var disposables = []; // geometries + materials à libérer

    // ----- Keyframes caméra (position + cible) par acte -----
    // p = position de progression ; les valeurs sont interpolées (lerp).
    var KF = [
      // Acte App : caméra serrée sur le téléphone pour LIRE l'écran
      { p: 0.0, pos: [0, 1.05, 3.6], tgt: [0, 1.0, 0] },
      { p: 0.28, pos: [0.4, 1.12, 3.2], tgt: [0, 1.05, 0] },
      // Transition / Scan : recul + travelling téléphone → borne
      { p: 0.42, pos: [2.4, 1.6, 6.2], tgt: [1.4, 1.4, -1.2] },
      { p: 0.55, pos: [4.2, 2.0, 7.0], tgt: [2.6, 2.0, -3.0] },
      // Acte Casier : on cadre la borne puis on balaye chaque composant
      // (cibles alignées sur les plages des cartes d'annotation P4).
      { p: 0.66, pos: [5.0, 3.4, 3.2], tgt: [4.2, 2.9, -3.6] }, // écran tactile (haut)
      { p: 0.74, pos: [5.4, 2.6, 2.6], tgt: [4.4, 1.7, -3.6] }, // lecteur QR / PIN
      { p: 0.81, pos: [5.6, 1.9, 2.6], tgt: [4.4, 1.2, -3.6] }, // clavier PIN
      { p: 0.88, pos: [3.2, 4.0, 3.4], tgt: [3.0, 3.7, -4.0] }, // panneau solaire (haut)
      { p: 0.95, pos: [1.4, 2.6, 3.6], tgt: [2.2, 2.2, -4.2] }, // casiers + LED (gauche)
      { p: 1.0, pos: [3.0, 2.6, 4.6], tgt: [3.0, 2.3, -4.4] }, // vue d'ensemble finale
    ];
    // Mobile : mouvements de caméra plus courts / reculés (moins de débordement)
    if (isMobile) {
      KF = [
        { p: 0.0, pos: [0, 1.1, 4.6], tgt: [0, 1.0, 0] },
        { p: 0.28, pos: [0.25, 1.15, 4.2], tgt: [0, 1.05, 0] },
        { p: 0.42, pos: [2.0, 1.7, 7.4], tgt: [1.4, 1.5, -1.4] },
        { p: 0.55, pos: [3.4, 2.1, 8.2], tgt: [2.6, 2.0, -3.0] },
        { p: 0.66, pos: [4.8, 3.4, 5.0], tgt: [4.2, 2.9, -3.6] },
        { p: 0.74, pos: [5.2, 2.6, 4.6], tgt: [4.4, 1.7, -3.6] },
        { p: 0.81, pos: [5.4, 1.9, 4.6], tgt: [4.4, 1.2, -3.6] },
        { p: 0.88, pos: [3.2, 4.0, 5.4], tgt: [3.0, 3.7, -4.0] },
        { p: 0.95, pos: [1.6, 2.6, 5.6], tgt: [2.2, 2.2, -4.2] },
        { p: 1.0, pos: [3.0, 2.6, 6.6], tgt: [3.0, 2.3, -4.4] },
      ];
    }

    var lerp = function (a, b, t) {
      return a + (b - a) * t;
    };
    function sampleKF(p) {
      var i = 0;
      for (; i < KF.length - 1; i++) {
        if (p <= KF[i + 1].p) break;
      }
      var a = KF[Math.min(i, KF.length - 1)];
      var b = KF[Math.min(i + 1, KF.length - 1)];
      var span = b.p - a.p || 1;
      var t = Math.max(0, Math.min(1, (p - a.p) / span));
      // easing doux (smoothstep)
      t = t * t * (3 - 2 * t);
      return {
        px: lerp(a.pos[0], b.pos[0], t),
        py: lerp(a.pos[1], b.pos[1], t),
        pz: lerp(a.pos[2], b.pos[2], t),
        tx: lerp(a.tgt[0], b.tgt[0], t),
        ty: lerp(a.tgt[1], b.tgt[1], t),
        tz: lerp(a.tgt[2], b.tgt[2], t),
      };
    }

    // ----- Légendes : on n'affiche que l'acte courant -----
    var captionEls = captionsWrap
      ? Array.prototype.slice.call(captionsWrap.querySelectorAll('.i3d-caption'))
      : [];
    var actRanges = [
      [0.0, 0.33],
      [0.33, 0.58],
      [0.58, 1.01],
    ];
    function updateCaptions(p) {
      var current = 0;
      for (var i = 0; i < actRanges.length; i++) {
        if (p >= actRanges[i][0] && p < actRanges[i][1]) {
          current = i;
          break;
        }
      }
      captionEls.forEach(function (el, i) {
        var on = i === current;
        el.style.opacity = on ? '1' : '0';
        el.style.transform = on ? 'translateY(0)' : 'translateY(14px)';
      });
      if (hint) hint.style.opacity = p < 0.06 ? '1' : '0';
    }

    // ----- Cartes d'annotation : une seule visible selon sa plage [s,e] -----
    var annotWrap = document.getElementById('i3d-annot');
    var annotEls = annotWrap
      ? Array.prototype.slice.call(annotWrap.querySelectorAll('.i3d-annot-card'))
      : [];
    var annotRanges = annotEls.map(function (el) {
      var r = (el.getAttribute('data-range') || '0,0').split(',');
      return [parseFloat(r[0]), parseFloat(r[1])];
    });
    var annotCurrent = -1;
    function updateAnnotations(p) {
      var next = -1;
      for (var i = 0; i < annotRanges.length; i++) {
        if (p >= annotRanges[i][0] && p < annotRanges[i][1]) {
          next = i;
          break;
        }
      }
      if (next === annotCurrent) return; // évite les écritures DOM inutiles
      annotCurrent = next;
      for (var j = 0; j < annotEls.length; j++) {
        if (j === next) annotEls[j].classList.add('is-on');
        else annotEls[j].classList.remove('is-on');
      }
    }

    // ====================================================================
    //  Construction de la scène
    // ====================================================================
    function build() {
      var W = stage.clientWidth || 800;
      var H = stage.clientHeight || 600;

      scene = new THREE.Scene();
      // P5 : color grade navy unifié + brume exponentielle pour la profondeur ciné.
      scene.fog = new THREE.FogExp2(0x0d1b2a, 0.03);
      camera = new THREE.PerspectiveCamera(38, W / H, 0.1, 100);
      renderer = new THREE.WebGLRenderer({ antialias: !isMobile, alpha: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, isMobile ? 1.5 : 2));
      renderer.setSize(W, H);
      // Fond navy plein (pas de gris/transparent plat) : cohérent avec le fog.
      renderer.setClearColor(0x0d1b2a, 1);
      stage.appendChild(renderer.domElement);

      renderer.domElement.addEventListener(
        'webglcontextlost',
        function (e) {
          e.preventDefault();
          stop();
          showFallback();
        },
        false,
      );

      // P5 — Éclairage « film » : ambient bas, key douce, fill froid,
      // et rim light teintée vert marque (#1D9E75) derrière les sujets pour
      // détourer la silhouette et créer un halo de marque.
      scene.add(new THREE.AmbientLight(0x1a2e42, 0.35));
      scene.add(new THREE.HemisphereLight(0x9ad6c0, 0x0d1b2a, 0.4));
      var key = new THREE.DirectionalLight(0xfff4e0, 0.95);
      key.position.set(7, 9, 8);
      scene.add(key);
      var fill = new THREE.DirectionalLight(0x3a86dd, 0.25);
      fill.position.set(-7, 4, 5);
      scene.add(fill);
      // Rim light verte derrière le téléphone (centre) et la borne (droite).
      var rimPhone = new THREE.PointLight(0x1d9e75, 1.6, 14, 2);
      rimPhone.position.set(0, 1.6, -2.6);
      scene.add(rimPhone);
      var rimMachine = new THREE.PointLight(0x1d9e75, 2.2, 16, 2);
      rimMachine.position.set(3.0, 3.0, -7.0);
      scene.add(rimMachine);

      // -------- Helpers géométrie (repris de LockerDistributor3D) --------
      function track(o) {
        if (o.geometry) disposables.push(o.geometry);
        if (o.material) {
          if (Array.isArray(o.material)) disposables.push.apply(disposables, o.material);
          else disposables.push(o.material);
        }
        return o;
      }
      function mat(c, r, m) {
        return new THREE.MeshStandardMaterial({
          color: c,
          roughness: r == null ? 0.65 : r,
          metalness: m == null ? 0.12 : m,
        });
      }
      function box(w, h, d, c, r, m) {
        return track(new THREE.Mesh(new THREE.BoxGeometry(w, h, d), mat(c, r, m)));
      }
      function emap(t, r, mt) {
        return new THREE.MeshStandardMaterial({
          map: t,
          roughness: r == null ? 0.5 : r,
          metalness: mt == null ? 0.05 : mt,
        });
      }
      function tex(w, h, draw) {
        var cv = document.createElement('canvas');
        cv.width = w;
        cv.height = h;
        draw(cv.getContext('2d'), w, h);
        var t = new THREE.CanvasTexture(cv);
        t.anisotropy = 4;
        return t;
      }
      function rshape(w, h, r) {
        var s = new THREE.Shape();
        r = Math.min(r, w / 2 - 0.001, h / 2 - 0.001);
        s.moveTo(-w / 2 + r, -h / 2);
        s.lineTo(w / 2 - r, -h / 2);
        s.absarc(w / 2 - r, -h / 2 + r, r, -Math.PI / 2, 0, false);
        s.lineTo(w / 2, h / 2 - r);
        s.absarc(w / 2 - r, h / 2 - r, r, 0, Math.PI / 2, false);
        s.lineTo(-w / 2 + r, h / 2);
        s.absarc(-w / 2 + r, h / 2 - r, r, Math.PI / 2, Math.PI, false);
        s.lineTo(-w / 2, -h / 2 + r);
        s.absarc(-w / 2 + r, -h / 2 + r, r, Math.PI, Math.PI * 1.5, false);
        return s;
      }
      function uvg(w, h) {
        var hw = w / 2,
          hh = h / 2;
        return {
          generateTopUV: function (g, v, a, b, c) {
            function u(i) {
              return new THREE.Vector2((v[i * 3] + hw) / w, (v[i * 3 + 1] + hh) / h);
            }
            return [u(a), u(b), u(c)];
          },
          generateSideWallUV: function () {
            return [
              new THREE.Vector2(0, 0),
              new THREE.Vector2(1, 0),
              new THREE.Vector2(1, 1),
              new THREE.Vector2(0, 1),
            ];
          },
        };
      }
      function rgeo(w, h, depth, r) {
        var g = new THREE.ExtrudeGeometry(rshape(w, h, r), {
          depth: depth,
          bevelEnabled: true,
          bevelThickness: 0.012,
          bevelSize: 0.012,
          bevelSegments: 1,
          curveSegments: 5,
          UVGenerator: uvg(w, h),
        });
        g.translate(0, 0, -depth / 2);
        return g;
      }
      function rcol(w, h, depth, r, c, ro, me) {
        return track(new THREE.Mesh(rgeo(w, h, depth, r), mat(c, ro, me)));
      }
      function rtex(w, h, depth, r, t, base, ro) {
        return track(new THREE.Mesh(rgeo(w, h, depth, r), [emap(t, ro == null ? 0.5 : ro), mat(base)]));
      }
      function rframe(ow, oh, iw, ih, depth, r, c, me) {
        var s = rshape(ow, oh, r);
        s.holes.push(rshape(iw, ih, Math.min(r, 0.05)));
        var g = new THREE.ExtrudeGeometry(s, {
          depth: depth,
          bevelEnabled: true,
          bevelThickness: 0.01,
          bevelSize: 0.01,
          bevelSegments: 1,
          curveSegments: 5,
        });
        g.translate(0, 0, -depth / 2);
        return track(new THREE.Mesh(g, mat(c, 0.5, me == null ? 0.3 : me)));
      }

      // =================================================================
      //  ACTE 1 — Le téléphone (au centre, écrans qui s'enchaînent)
      // =================================================================
      var phone = new THREE.Group();
      phone.position.set(0, 1.0, 0);
      scene.add(phone);

      // Coque
      var shell = rcol(1.05, 2.1, 0.16, 0.18, 0x14181d, 0.45, 0.4);
      phone.add(shell);
      // Cadre interne
      var bez = rcol(0.98, 2.02, 0.04, 0.15, 0x0b0e12, 0.4, 0.2);
      bez.position.z = 0.082;
      phone.add(bez);

      // Trois textures d'écran d'app (carte → durée → QR)
      function screenMap() {
        function header(g, w) {
          g.fillStyle = '#1D9E75';
          g.fillRect(0, 0, w, 90);
          g.fillStyle = '#ffffff';
          g.beginPath();
          g.arc(34, 48, 11, 0, 7);
          g.fill();
          g.fillStyle = '#ffffff';
          g.font = "700 36px Syne, 'DM Sans', system-ui, sans-serif";
          g.fillText('SportLocker', 56, 60);
        }
        var s1 = tex(420, 860, function (g, w, h) {
          g.fillStyle = '#FFFFFF';
          g.fillRect(0, 0, w, h);
          // pseudo-carte (gris bleuté plus contrasté)
          g.fillStyle = '#cfd8e2';
          g.fillRect(0, 90, w, h - 90);
          g.strokeStyle = '#aab6c4';
          g.lineWidth = 2;
          for (var i = 1; i < 7; i++) {
            g.beginPath();
            g.moveTo(0, 90 + i * 110);
            g.lineTo(w, 90 + i * 110);
            g.stroke();
            g.beginPath();
            g.moveTo(i * 60, 90);
            g.lineTo(i * 60, h);
            g.stroke();
          }
          // pins (le sélectionné en vert marque, halo)
          var pins = [[120, 320], [280, 500], [200, 660]];
          pins.forEach(function (p, idx) {
            if (idx === 1) {
              g.fillStyle = 'rgba(29,158,117,0.22)';
              g.beginPath();
