---
interface FaqItem {
  q: string
  a: string
  // Mention discrète « Bientôt » (ex. fonctionnalité en cours de déploiement).
  // Rendue sous la réponse en fine print + badge, et reflétée dans le JSON-LD
  // pour que les données structurées restent cohérentes avec le visible.
  note?: string
}
interface Props {
  items: FaqItem[]
}
const { items } = Astro.props

// Données structurées FAQPage (schema.org) → éligibilité aux résultats
// enrichis Google. Émis automatiquement pour chaque page qui rend <Faq/>.
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.note ? `${item.a} Bientôt : ${item.note}` : item.a,
    },
  })),
}
---

<div class="flex flex-col gap-3 max-w-3xl mx-auto">
  {items.map((item) => (
    <details
      data-reveal
      class="group card-dark px-6 py-5 open:bg-white/[0.06] transition-colors"
    >
      <summary
        class="flex justify-between items-center cursor-pointer list-none font-medium text-white text-[0.95rem]"
      >
        <span>{item.q}</span>
        <span
          class="text-brand-400 text-xl transition-transform group-open:rotate-45 select-none"
          aria-hidden="true">+</span
        >
      </summary>
      <p class="mt-3 text-sm text-white/65 leading-relaxed font-light">{item.a}</p>
      {item.note && (
        <p class="mt-3 flex items-start gap-2.5 text-[0.72rem] text-white/45 font-light leading-relaxed">
          <span class="mt-px inline-flex shrink-0 items-center gap-1.5 rounded-full border border-brand-500/25 bg-brand-500/[0.08] px-2 py-0.5 text-[0.6rem] font-medium uppercase tracking-[0.14em] text-brand-300">
            <span class="h-1 w-1 rounded-full bg-brand-400" aria-hidden="true"></span>Bientôt
          </span>
          <span>{item.note}</span>
        </p>
      )}
    </details>
  ))}
</div>

<script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
