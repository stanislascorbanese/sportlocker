---
import { NAV } from '@/data/site'
const path = Astro.url.pathname
---

<nav id="nav">
  <div class="container-x">
    <div class="flex items-center justify-between gap-8">
      <a href="/" class="flex items-center gap-2.5 no-underline" aria-label="SportLocker — accueil">
        <img src="/brand/logo-icon-outline.png" alt="" class="w-11 h-11" width="44" height="44" />
        <span class="font-extrabold text-[1.15rem] text-white">
          Sport<span class="text-brand-500">Locker</span>
        </span>
      </a>

      <ul class="hidden md:flex items-center gap-7 list-none">
        {
          NAV.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  'text-sm transition-colors',
                  path === item.href ? 'text-white' : 'text-white/65 hover:text-white',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>

      <div class="flex items-center gap-3">
        <a href="/contact" class="hidden sm:inline-flex btn btn-primary btn-sm">
          Demander un devis
        </a>
        <button
          id="hamburger"
          class="md:hidden p-2 flex flex-col gap-[5px]"
          aria-label="Menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span class="block w-5 h-[2px] bg-white rounded"></span>
          <span class="block w-5 h-[2px] bg-white rounded"></span>
          <span class="block w-5 h-[2px] bg-white rounded"></span>
        </button>
      </div>
    </div>
  </div>
</nav>

<div
  id="mobile-menu"
  class="hidden md:hidden fixed inset-x-0 top-[68px] bottom-0 bg-navy-900 z-[99] p-8 flex-col gap-6 border-t border-white/10"
>
  {NAV.map((item) => (
    <a href={item.href} class="text-lg text-white/85 border-b border-white/10 pb-3">
      {item.label}
    </a>
  ))}
  <a href="/contact" class="btn btn-primary mt-2">Demander un devis →</a>
</div>

<script is:inline>
  const btn = document.getElementById('hamburger')
  const menu = document.getElementById('mobile-menu')
  if (btn && menu) {
    const toggle = () => {
      const open = menu.classList.toggle('hidden') === false
      menu.classList.toggle('flex', open)
      btn.setAttribute('aria-expanded', String(open))
      document.body.style.overflow = open ? 'hidden' : ''
    }
    btn.addEventListener('click', toggle)
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', toggle))
    window.addEventListener('resize', () => {
      if (window.innerWidth > 768 && !menu.classList.contains('hidden')) toggle()
    })
  }
</script>
