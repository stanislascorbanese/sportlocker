      var occDir = new THREE.Vector3();
      function isOccluded(anchor) {
        occDir.subVectors(anchor, camera.position);
        var dist = occDir.length();
        occDir.normalize();
        occRay.set(camera.position, occDir);
        occRay.far = dist;
        var hits = occRay.intersectObject(machine, true);
        for (var i = 0; i < hits.length; i++) {
          if (hits[i].distance < dist - 0.04) return true;
        }
        return false;
      }

      function updateLabels() {
        if (!showLabels) return;
        var Wp = stage.clientWidth,
          Hp = stage.clientHeight;
        LABELS.forEach(function (L) {
          var d = L.div,
            cy = d.offsetTop + d.offsetHeight / 2,
            cx = L.side === 'left' ? d.offsetLeft + d.offsetWidth : d.offsetLeft;
          vp.copy(L.a).project(camera);
          if (vp.z <= 1) {
            var sx = (vp.x * 0.5 + 0.5) * Wp,
              sy = (-vp.y * 0.5 + 0.5) * Hp;
            L.line.setAttribute('x1', cx);
            L.line.setAttribute('y1', cy);
            L.line.setAttribute('x2', sx);
            L.line.setAttribute('y2', sy);
            L.dot.setAttribute('cx', sx);
            L.dot.setAttribute('cy', sy);
            L.line.style.display = '';
            L.dot.style.display = '';
            var occluded = isOccluded(L.a);
            L.line.setAttribute('stroke-dasharray', occluded ? '5 4' : '');
            L.line.setAttribute('stroke-opacity', occluded ? '0.55' : '1');
            L.dot.setAttribute('fill-opacity', occluded ? '0.5' : '1');
          } else {
            L.line.style.display = 'none';
            L.dot.style.display = 'none';
          }
        });
      }
      function loop() {
        requestAnimationFrame(loop);
        if (autoR) {
          theta += 0.0035;
          place();
        }
        doors.forEach(function (d) {
          if (Math.abs(d.cur - d.target) > 0.001) {
            d.cur += (d.target - d.cur) * 0.18;
            d.pivot.rotation.y = d.cur;
          }
        });
        renderer.render(scene, camera);
        updateLabels();
      }
      layout();
      loop();
      if (window.ResizeObserver) {
        new ResizeObserver(function () {
          var w = stage.clientWidth || 680;
          renderer.setSize(w, H);
          camera.aspect = w / H;
          camera.updateProjectionMatrix();
          layout();
        }).observe(stage);
      }
    }

    function loadThree() {
      if (loaded) return;
      loaded = true;
      if (window.THREE) {
        init();
        return;
      }
      var s = document.createElement('script');
      s.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
      s.onload = init;
      s.onerror = function () {
        stage.innerHTML =
          '<div style="padding:2rem;color:rgba(255,255,255,0.55);font-size:14px">Le moteur 3D n\'a pas pu se charger.</div>';
      };
      document.head.appendChild(s);
    }

    // Lazy-load à l'approche du viewport, avec garde-fous : certains navigateurs
    // (sessions automatisées, IO throttlé, vieux moteurs) ne déclenchent jamais
    // le callback IO même pour un élément visible. On ajoute donc un fallback
    // scroll + des checks géométriques différés pour garantir le chargement.
    function nearViewport() {
      var r = stage.getBoundingClientRect();
      var vh = window.innerHeight || document.documentElement.clientHeight;
      return r.top < vh * 1.4 && r.bottom > -vh * 0.4;
    }
    function maybeLoad() {
      if (!loaded && nearViewport()) loadThree();
    }
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(
        function (entries) {
          for (var i = 0; i < entries.length; i++) {
            if (entries[i].isIntersecting) {
              loadThree();
              io.disconnect();
              break;
            }
          }
        },
        { rootMargin: '300px 0px' },
      );
      io.observe(stage);
    }
    window.addEventListener('scroll', maybeLoad, { passive: true });
    window.addEventListener('resize', maybeLoad, { passive: true });
    [200, 800, 1600].forEach(function (t) {
      setTimeout(maybeLoad, t);
    });
    maybeLoad();
  })();
</script>
