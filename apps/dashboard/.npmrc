# Settings pnpm pour le dashboard.
#
# Ce fichier ne FORCE pas Railway à utiliser pnpm — Railway/Nixpacks détecte
# le package manager via la présence d'un lockfile dans le root du service.
# C'est nixpacks.toml + railway.json (à côté) qui font ce choix explicite.
#
# Ces options assurent un comportement consistant entre local et Railway :

engine-strict=true
auto-install-peers=true
strict-peer-dependencies=false
