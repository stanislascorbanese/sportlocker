# ════════════════════════════════════════════════════════════════════════
#  SportLocker — variables d'environnement PRODUCTION (Railway).
# ════════════════════════════════════════════════════════════════════════
#  À copier dans Railway → Service → Variables. Les marqués (auto) sont
#  fournis automatiquement par Railway via les add-ons Postgres et Redis ;
#  ne PAS les déclarer manuellement.
# ════════════════════════════════════════════════════════════════════════

# ─── Runtime ─────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
# PORT est injecté par Railway → l'entrypoint le remappe sur API_PORT.
# PORT=                                          # (auto)
API_HOST=0.0.0.0

# ─── PostgreSQL (Railway Postgres add-on) ───────────────────────────────
# DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DB  # (auto)

# ─── Redis (Railway Redis add-on ou Upstash) ────────────────────────────
# REDIS_URL=redis://default:PASSWORD@HOST:PORT       # (auto)

# ─── MQTT (EMQX Cloud) ───────────────────────────────────────────────────
MQTT_URL=mqtts://<your-deployment>.emqxcloud.com:8883
MQTT_USERNAME=sportlocker-api
MQTT_PASSWORD=<change-me-strong>

# ─── JWT signatures (32+ chars chacun, GÉNÉRÉS via openssl) ─────────────
# openssl rand -base64 48 | tr -d '\n='
JWT_SESSION_SECRET=<48-bytes-base64-required>
JWT_DEVICE_SECRET=<48-bytes-base64-required>

# ─── Firebase Auth (Service Account JSON minifié sur une ligne) ─────────
FIREBASE_PROJECT_ID=sportlocker-prod
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"..."}

# ─── Stripe (paiement caution) ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_<your-key>
STRIPE_WEBHOOK_SECRET=whsec_<your-webhook-secret>

# ─── Push notifications (Expo) ──────────────────────────────────────────
EXPO_ACCESS_TOKEN=<expo-personal-access-token>

# ─── Notes ──────────────────────────────────────────────────────────────
# • CORS : si la mobile app et le dashboard sont sur des origines connues,
#   ajouter une variable CORS_ALLOWED_ORIGINS et la consommer côté @fastify/cors.
# • Sentry : SENTRY_DSN si on branche le SDK plus tard.
# • Le migrateur (scripts/migrate.mjs) s'exécute à chaque déploiement via
#   l'entrypoint Docker — pas de variable à régler.
