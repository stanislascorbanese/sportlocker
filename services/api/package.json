{
  "name": "@sportlocker/api",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:seed": "node ./scripts/seed.mjs",
    "db:seed-fw-sim": "node ./scripts/seed-firmware-sim.mjs",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts",
    "bootstrap-super-admin": "node ./scripts/bootstrap-super-admin.mjs",
    "onboard-tenant": "node ./scripts/onboard-tenant.mjs",
    "gen:openapi": "node ./scripts/gen-openapi.mjs",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@fastify/websocket": "^11.2.0",
    "@sentry/node": "^8.0.0",
    "bullmq": "^5.78.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.2",
    "firebase-admin": "^12.1.0",
    "ioredis": "^5.11.1",
    "jose": "^5.2.0",
    "mqtt": "^5.5.0",
    "pino": "^9.0.0",
    "postgres": "^3.4.4",
    "stripe": "^15.0.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@sportlocker/types": "workspace:*",
    "@testcontainers/postgresql": "^10.9.0",
    "@types/node": "^22.0.0",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "pino-pretty": "^11.0.0",
    "testcontainers": "^10.9.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^7.0.0",
    "vitest": "^4.1.8"
  }
}
